.forms-scope {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 20px;
  outline: 2px solid rgb(107 77 214 / 28%);
  outline-offset: 2px;
  background: linear-gradient(180deg, #f7ebff 0%, #ffeaf5 100%);
  border-radius: 20px;
}

.forms-scope__input {
  outline: 2px solid rgb(247.62 242.94 254.1 / 40%);
  outline-offset: 2px;
  background: rgb(247.62 242.94 254.1);
  border-radius: 12px;
}

.forms-scope__button {
  text-transform: uppercase;
  letter-spacing: 0.08em;
  outline: 2px solid rgb(107 77 214 / 40%);
  outline-offset: 2px;
  background: #6b4dd6;
  border-radius: 999px;
}

.forms-scope__badge {
  outline: 2px solid rgb(224.66 205.42 251.3 / 40%);
  outline-offset: 2px;
  background: rgb(224.66 205.42 251.3);
  border-radius: 32px;
}