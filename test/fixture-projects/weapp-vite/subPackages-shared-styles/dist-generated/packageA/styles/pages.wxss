.page-scope {
  position: relative;
  padding: 16px;
  margin: 0;
  border-radius: 18px;
}

.page-scope {
  color: #2a1230;
  background: linear-gradient(135deg, #ff9ec7 0%, #f96fa3 100%);
  border: 1px solid #f96fa3;
}

.page-scope::before {
  position: absolute;
  top: -12px;
  right: 12px;
  font-size: 12px;
  color: rgb(42 18 48 / 45%);
  letter-spacing: 0.08em;
  content: "[page]";
}

.page-scope {
  box-shadow: 0 16px 32px rgb(58 26 45 / 24%);
}

.page-ribbon--hero {
  padding: 4px 10px;
  background: rgb(255 158 199 / 35%);
  border-left: 3px solid #ff9ec7;
}

.page-ribbon--accent {
  padding: 4px 10px;
  background: rgb(249 111 163 / 35%);
  border-left: 3px solid #f96fa3;
}

.page-ribbon--subtle {
  padding: 4px 10px;
  background: rgb(255 227 238 / 35%);
  border-left: 3px solid #ffe3ee;
}