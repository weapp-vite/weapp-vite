.component-theme {
  color: #4169e1;
  background: linear-gradient(145deg, rgb(65 105 225 / 16%), rgb(255 255 255 / 55%));
  border: 2px solid rgb(65 105 225 / 50%);
  box-shadow: 0 8px 24px rgb(65 105 225 / 28%);
}

.component-theme--primary {
  padding: 6px 10px;
  background: rgb(65 105 225 / 18%);
  border-color: #5b7ee5;
}

.component-theme--muted {
  padding: 6px 10px;
  background: #fff;
  border-color: rgb(65 105 225 / 45%);
  border-style: dashed;
}

.component-theme--warning {
  padding: 6px 10px;
  background: rgb(246 173 85 / 25%);
  border-color: #f39625;
}
