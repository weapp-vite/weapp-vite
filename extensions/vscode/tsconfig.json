{
  "compilerOptions": {
    "target": "ES2020",
    "rootDir": ".",
    "module": "Node16",
    "moduleResolution": "Node16",
    "resolveJsonModule": true,
    "types": [
      "node"
    ],
    "strict": false,
    "declaration": false,
    "outDir": "dist",
    "sourceMap": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "extension.ts",
    "extension/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "dist",
    "extension/**/*.test.ts",
    "scripts/**/*.ts"
  ]
}
