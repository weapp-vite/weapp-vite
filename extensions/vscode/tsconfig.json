{
  "compilerOptions": {
    "target": "ES2022",
    "rootDir": "../..",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "weapp-vite": [
        "../../packages/weapp-vite/dist/index.d.mts"
      ],
      "weapp-vite/*": [
        "../../packages/weapp-vite/dist/*"
      ],
      "@weapp-vite/ast/babel": [
        "../../packages/ast/src/babel.ts"
      ],
      "@weapp-vite/ast/babelTypes": [
        "../../packages/ast/src/babelTypes.ts"
      ]
    },
    "resolveJsonModule": true,
    "types": [
      "node",
      "vscode"
    ],
    "strict": false,
    "declaration": false,
    "outDir": "dist",
    "sourceMap": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "extension.ts",
    "extension/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "dist",
    "extension/**/*.test.ts"
  ]
}
