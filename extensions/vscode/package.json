    "onCommand:weapp-vite.copyCurrentPageRoute",
    "onCommand:weapp-vite.copyPageRouteFromTreeItem",
    "onCommand:weapp-vite.revealCurrentPageInAppJson",
    "onCommand:weapp-vite.revealCurrentPageInPagesTree",
    "onCommand:weapp-vite.refreshPagesTree",
    "onCommand:weapp-vite.filterProblemPagesInTree",
