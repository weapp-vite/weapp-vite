{
  "publisher": "weapp-vite",
  "name": "@weapp-vite/vscode",
  "displayName": "weapp-vite",
  "type": "module",
  "version": "0.1.3",
  "private": true,
  "description": "为 weapp-vite 项目提供命令入口、状态栏、代码片段、自定义块高亮与轻量编辑器增强的 VS Code 扩展。",
  "license": "MIT",
  "homepage": "https://github.com/weapp-vite/weapp-vite/tree/main/extensions/vscode",
  "repository": {
    "type": "git",
    "url": "https://github.com/weapp-vite/weapp-vite.git",
    "directory": "extensions/vscode"
  },
  "bugs": {
    "url": "https://github.com/weapp-vite/weapp-vite/issues"
  },
  "x-vsce": {
    "name": "weapp-vite",
    "displayName": "Weapp Vite"
  },
  "keywords": [
    "weapp-vite",
    "vue",
    "volar",
    "textmate",
    "syntax",
    "jsonc",
    "miniprogram",
    "wechat",
    "vite"
  ],
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "main": "./dist/extension.js",
  "icon": "assets/logo.png",
