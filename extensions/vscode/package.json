    "workspaceContains:**/vite.config.js",
    "workspaceContains:**/vite.config.mjs",
    "workspaceContains:**/vite.config.cjs",
    "workspaceContains:**/weapp-vite.config.ts",
    "workspaceContains:**/weapp-vite.config.mts",
    "workspaceContains:**/weapp-vite.config.cts",
    "workspaceContains:**/weapp-vite.config.js",
    "workspaceContains:**/weapp-vite.config.mjs",
    "workspaceContains:**/weapp-vite.config.cjs",
