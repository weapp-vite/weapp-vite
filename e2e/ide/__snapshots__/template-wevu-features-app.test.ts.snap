  </view>
  <view class="router-stability-page__btn" id="router-index-wx" data-wi-tap="i1">
    当前页触发 wx.navigateTo('./target/index')
  </view>
  <view class="router-stability-page__btn" id="router-index-page-router" data-wi-tap="i2">
    当前页触发 pageRouter.navigateTo('./target/index')
  </view>
</view>
"
`;

