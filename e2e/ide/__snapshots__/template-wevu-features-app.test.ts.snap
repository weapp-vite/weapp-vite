exports[`template e2e: wevu-features-app > renders all pages from app config > wevu-features-app::pages/use-provide-inject-scope/index 1`] = `
"<weapp-layout-provide-inject-scope __wvSlotOwnerId="{{__wvSlotOwnerId || __wvOwnerId || ''}}">
  <view class="provide-inject-scope-page">
    <view class="provide-inject-scope-page__title">wevu provide / inject 深层作用域复现</view>
    <view class="provide-inject-scope-page__line" id="scope-page-provider">
      page provide = page-provide-value
    </view>
    <ProvideInjectScopeMiddle />
    <ProvideInjectSlotProvider
      generic:scoped-slots-default="scoped-slot-stable-default-0"
      vue-slots="{{ {default:true} }}"
      __wvSlotOwnerId="{{__wvSlotOwnerId || __wvOwnerId || ''}}" />
  </view>
</weapp-layout-provide-inject-scope>
"
`;

exports[`template e2e: wevu-features-app > renders all pages from app config > wevu-features-app::pages/use-slots/index 1`] = `
"<view class="use-slots-page">
  <view class="use-slots-page__title">wevu useSlots 特性展示</view>
  <view class="use-slots-page__subtitle">控制 slot 展示和内容，查看 slots 键与 class 变化</view>
  <view class="use-slots-page__toolbar">
    <view class="{{__wv_cls_0}}" id="slots-ctrl-open" data-wi-tap="i0">
      panel: {{controlState.open ? 'open' : 'closed'}}
    </view>
    <view class="{{__wv_cls_1}}" id="slots-ctrl-header" data-wi-tap="i1">
      header slot: {{controlState.withHeader ? 'on' : 'off'}}
    </view>
    <view class="use-slots-page__btn" id="slots-ctrl-count" data-wi-tap="i2">
      count: {{controlState.count}}
    </view>
  </view>
  <view class="{{__wv_cls_2}}" id="slots-open-state">
    open state: {{controlState.open ? 'open' : 'closed'}}
  </view>
  <UseSlotsFeature
    title="组件内 useSlots()"
    open="{{controlState.open}}"
    vue-slots="{{ {header:true,default:true} }}">
    <weapp-slot-wrapper slot="header">
      <block wx:if="{{controlState.withHeader}}">
        <view class="use-slots-page__header">header slot content</view>
      </block>
    </weapp-slot-wrapper>
    <view class="use-slots-page__body">default slot content {{controlState.count}}</view>
  </UseSlotsFeature>
</view>
"
`;

