      </view>
      <view class="use-store-page__btn" id="store-setup-reset" data-wi-tap="i6">setup reset</view>
    </view>
  </view>
  <view class="{{__wv_cls_1}}">
    <view class="use-store-page__section-title">options store</view>
    <view class="use-store-page__line" id="store-options-count">
      options count = {{optionsCountValue}}
    </view>
    <view class="use-store-page__line" id="store-options-doubled">
