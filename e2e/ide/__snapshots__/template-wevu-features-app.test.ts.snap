    用于验证 wx.navigateTo 与 this.pageRouter.navigateTo 的相对路径基准差异。
  </view>
  <view class="router-stability-page__btn" id="router-open-sub">打开 sub 页面</view>
  <view class="router-stability-page__btn" id="router-index-wx">
    当前页触发 wx.navigateTo('./target/index')
  </view>
  <view class="router-stability-page__btn" id="router-index-page-router">
    当前页触发 pageRouter.navigateTo('./target/index')
  </view>
</view>
"
`;

exports[`template e2e: wevu-features-app > renders all pages from app config > wevu-features-app::pages/router-stability/sub/index 1`] = `
"<view class="router-sub-page">
  <view class="router-sub-page__title">router stability (sub page)</view>
  <view class="router-sub-page__desc">本页会调用上一个页面的方法，验证相对路径基准是否稳定。</view>
  <view class="router-sub-page__btn" id="router-sub-call-prev-wx">
    调用上页 wx.navigateTo('./target/index')
  </view>
  <view class="router-sub-page__btn" id="router-sub-call-prev-page-router">
    调用上页 pageRouter.navigateTo('./target/index')
  </view>
  <routeroriginprobe is="components/router-origin-probe/index" class="__wv-ref-0">
    <view class="index--router-origin-probe">
      <view class="index--router-origin-probe__title">component router origin probe</view>
      <view class="index--router-origin-probe__btn" id="cmp-router-nav">
        this.router.navigateTo('./target/index')
      </view>
      <view class="index--router-origin-probe__btn" id="cmp-page-router-nav">
        this.pageRouter.navigateTo('./target/index')
      </view>
    </view>
  </routeroriginprobe>
  <view class="router-sub-page__btn" id="router-sub-call-component-router">
    组件 this.router.navigateTo('./target/index')
  </view>
  <view class="router-sub-page__btn" id="router-sub-call-component-page-router">
    组件 this.pageRouter.navigateTo('./target/index')
  </view>
</view>
"
`;

