exports[`template e2e: wevu-features-app > renders all pages from app config > wevu-features-app::pages/use-attrs/index 1`] = `
"<view class="use-attrs-page">
  <view class="use-attrs-page__title">wevu useAttrs 特性展示</view>
  <view class="use-attrs-page__subtitle">下面按钮控制的是组件的非 props 参数（attrs）</view>
  <view class="use-attrs-page__toolbar">
    <view id="ctrl-cycle-tone" class="use-attrs-page__btn wevu-features-btn-cycle-tone tone-blue">
      切换 tone：tone-blue
    </view>
    <view
      id="ctrl-toggle-visible"
      class="use-attrs-page__btn wevu-features-btn-toggle-visible ctrl-on">
      切换 visible：true
    </view>
    <view
      id="ctrl-toggle-border"
      style="border: 1px dashed #64748b; padding: 4px 8px"
      class="use-attrs-page__btn wevu-features-btn-toggle-border ctrl-dash">
      边框模式：dash
    </view>
    <view class="use-attrs-page__btn wevu-features-btn-bump-seed" id="ctrl-bump-seed">
      递增 seed：1
    </view>
  </view>
  <useattrsfeature is="components/use-attrs-feature/index">
    <view class="index--use-attrs-feature">
      <view class="index--use-attrs-feature__title">组件内 useAttrs()</view>
      <view
        id="attrs-badge"
        style="border: 1px dashed #64748b; padding: 4px 8px"
        class="index--use-attrs-feature__badge index--tone-blue">
        state-class = tone-blue
      </view>
      <view id="attrs-flag" class="index--use-attrs-feature__flag index--is-on">
        visible = true
      </view>
      <view class="index--use-attrs-feature__extra" id="attrs-extra">extra-label = seed-1</view>
      <view class="index--use-attrs-feature__rows">
        <view class="index--use-attrs-feature__row">__wv_cls_0: use-attrs-feature__badge</view>
        <view class="index--use-attrs-feature__row">__wv_cls_1: use-attrs-feature__flag</view>
        <view class="index--use-attrs-feature__row">__wv_style_0:</view>
        <view class="index--use-attrs-feature__row">
          badge-style: border: 2rpx dashed #64748b; padding: 8rpx 16rpx;
        </view>
        <view class="index--use-attrs-feature__row">extra-label: seed-1</view>
        <view class="index--use-attrs-feature__row">seed-tag: 1</view>
        <view class="index--use-attrs-feature__row">state-class: tone-blue</view>
        <view class="index--use-attrs-feature__row">visible: true</view>
      </view>
    </view>
  </useattrsfeature>
</view>
"
`;

