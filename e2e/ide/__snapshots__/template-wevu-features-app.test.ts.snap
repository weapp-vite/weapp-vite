exports[`template e2e: wevu-features-app > renders all pages from app config > wevu-features-app::pages/use-attrs/index 1`] = `
"<view class="use-attrs-page">
  <view class="use-attrs-page__title">wevu useAttrs 特性展示</view>
  <view class="use-attrs-page__subtitle">下面按钮控制的是组件的非 props 参数（attrs）</view>
  <view class="use-attrs-page__toolbar">
    <view class="{{__wv_cls_0}}" id="ctrl-cycle-tone" data-wi-tap="i0">
      切换 tone：{{currentToneClass}}
    </view>
    <view class="{{__wv_cls_1}}" id="ctrl-toggle-visible" data-wi-tap="i1">
      切换 visible：{{controlState.visible ? 'true' : 'false'}}
    </view>
    <view style="{{__wv_style_0}}" class="{{__wv_cls_2}}" id="ctrl-toggle-border" data-wi-tap="i2">
      边框模式：{{controlState.strongBorder ? 'strong' : 'dash'}}
    </view>
    <view
      class="use-attrs-page__btn wevu-features-btn-bump-seed"
      id="ctrl-bump-seed"
      data-wi-tap="i3">
      递增 seed：{{controlState.seed}}
    </view>
  </view>
  <block wx:if="{{featureMounted}}">
    <UseAttrsFeature
      title="组件内 useAttrs()"
      stateClass="{{currentToneClass}}"
      visible="{{controlState.visible}}"
      badgeStyle="{{currentBadgeStyle}}"
      extraLabel="{{currentExtraLabel}}"
      seedTag="{{controlState.seed}}" />
  </block>
</view>
"
`;

exports[`template e2e: wevu-features-app > renders all pages from app config > wevu-features-app::pages/use-model/index 1`] = `
"<view class="use-model-page">
  <view class="use-model-page__title">wevu useModel 特性展示</view>
  <view class="use-model-page__subtitle">
    父组件与子组件双向更新 modelValue，并记录 update:modelValue
  </view>
  <view class="use-model-page__toolbar">
    <view class="use-model-page__btn" id="model-parent-alpha" data-wi-tap="i0">
      parent -&gt; alpha
    </view>
    <view class="use-model-page__btn" id="model-parent-beta" data-wi-tap="i1">
      parent -&gt; beta
    </view>
  </view>
  <view class="use-model-page__value" id="model-parent-value">
    parent modelValue = {{modelValue}}
  </view>
  <view class="use-model-page__value" id="model-parent-title">parent title = {{childTitle}}</view>
  <view class="use-model-page__value" id="model-log-size">emit logs = {{emitLogs.length}}</view>
  <UseModelFeature
    title="{{childTitle}}"
    data-wd-update-title="1"
    data-wi-update-title="i2"
    bind:update-title="__weapp_vite_inline"
    modelValue="{{modelValue}}"
    data-wd-update-modelvalue="1"
    data-wi-update-modelvalue="i3"
    bind:update-modelvalue="__weapp_vite_inline" />
</view>
"
`;

