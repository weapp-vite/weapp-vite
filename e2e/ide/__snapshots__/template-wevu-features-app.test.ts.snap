exports[`template e2e: wevu-features-app > renders all pages from app config > wevu-features-app::pages/index/index 1`] = `
"<view class="feature-nav-page">
  <view class="feature-nav-title">wevu 特性展示</view>
  <view class="feature-nav-subtitle">选择一个特性场景进入</view>
  <view class="feature-nav-list">
    <navigator
      class="feature-nav-item"
      wx:for="{{featureList}}"
      wx:for-item="item"
      wx:for-index="__wv_index_0"
      wx:key="key"
      url="{{item.path}}">
      <view class="feature-nav-item-title">{{item.title}}</view>
      <view class="feature-nav-item-summary">{{item.summary}}</view>
    </navigator>
  </view>
</view>
"
`;

exports[`template e2e: wevu-features-app > renders all pages from app config > wevu-features-app::pages/native-uses-vue/index 1`] = `
"<view class="native-interop-page">
  <view class="native-interop-page__title">原生组件引入 Vue 组件</view>
  <view class="native-interop-page__subtitle">验证 native usingComponents -&gt; Vue SFC 链路</view>
  <view class="native-interop-page__toolbar">
    <view class="native-interop-page__btn" id="native-interop-toggle" data-wi-tap="i0">
      mode: {{currentMode}}
    </view>
    <view class="native-interop-page__btn" id="native-interop-count" data-wi-tap="i1">
      count: {{count}}
    </view>
  </view>
  <NativeUsesVue
    title="原生组件引入 Vue 组件（static）"
    subtitle="native -> vue static chain"
    badge="static"
    note="这段文本由原生组件传递给 Vue 组件。" />
</view>
"
`;

exports[`template e2e: wevu-features-app > renders all pages from app config > wevu-features-app::pages/router-coverage/index 1`] = `
"<view class="router-coverage-page">
  <view class="router-coverage-page__title">wevu/router 页面跳转覆盖</view>
  <view class="router-coverage-page__subtitle">
    覆盖主包、普通分包、独立分包跳转，以及 beforeEach / beforeEnter / beforeResolve / afterEach /
    onError
  </view>
  <view class="router-coverage-page__panel">
    <view class="router-coverage-page__line" id="router-coverage-route">
      current route = {{routeSummary}}
    </view>
    <view class="router-coverage-page__line" id="router-coverage-action">
      last action = {{actionSummary}}
    </view>
  </view>
  <view class="router-coverage-page__section-title">页面跳转</view>
  <view
    class="router-coverage-page__card"
    wx:for="{{ROUTER_COVERAGE_TARGETS}}"
    wx:for-item="item"
    wx:for-index="__wv_index_0"
    wx:key="key">
    <view class="router-coverage-page__card-title">{{item.title}}</view>
    <view class="router-coverage-page__card-summary">{{item.summary}}</view>
    <view class="router-coverage-page__actions">
      <view
        class="router-coverage-page__btn"
        data-wi-tap="i0"
        data-wv-s0="{{item}}"
        data-wv-i0="{{__wv_index_0}}">
        push 到当前页
      </view>
      <block wx:if="{{item.key === 'independent'}}">
        <view
          class="router-coverage-page__btn router-coverage-page__btn--secondary"
          data-wi-tap="i1"
          data-wv-s0="{{item}}"
          data-wv-i0="{{__wv_index_0}}">
          replace 到当前页
        </view>
      </block>
    </view>
  </view>
  <view class="router-coverage-page__section-title">守卫触发</view>
  <view class="router-coverage-page__actions">
    <view class="router-coverage-page__btn" id="router-coverage-blocked" data-wi-tap="i2">
      触发 beforeEach 阻断
    </view>
    <view
      class="router-coverage-page__btn router-coverage-page__btn--warn"
      id="router-coverage-error"
      data-wi-tap="i3">
      触发 beforeResolve 报错
    </view>
    <view
      class="router-coverage-page__btn router-coverage-page__btn--secondary"
      id="router-coverage-back"
      data-wi-tap="i4">
      调用 router.back()
    </view>
  </view>
</view>
"
`;

