    </view>
    <view class="use-store-page__toolbar">
      <view class="use-store-page__btn" id="store-options-inc" data-wi-tap="i7">options inc</view>
      <view class="use-store-page__btn" id="store-options-rename" data-wi-tap="i8">
        options rename
      </view>
      <view class="use-store-page__btn" id="store-options-patch-object" data-wi-tap="i9">
