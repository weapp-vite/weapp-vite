exports[`template e2e: weapp-vite-tailwindcss-template > renders all pages from app config > weapp-vite-tailwindcss-template::pages/index/index 1`] = `
"<view
  class="min-h-screen {{ mode === 'light'?'bg-gray-100 text-slate-800':'bg-gray-900 text-slate-200' }} transition-colors duration-500">
  <view class="flex flex-col items-center pt-6 space-y-4">
    <view class="flex space-x-8">
      <view
        class="w-24 h-24 bg-_burl_phttps_c_f_fvite_dicebreaker_dtop_flogo_dpng_P_B bg-_blength_c100_v_100_v_B bg-no-repeat"></view>
      <view
        class="w-32 h-24 bg-_burl_phttps_c_f_fvite_dicebreaker_dtop_ftw-logo_dpng_P_B bg-_blength_c100_v_100_v_B bg-no-repeat"></view>
    </view>
    <view
      class="bg-linear-to-r from-green-400 to-sky-400 bg-clip-text text-xl font-extrabold text-transparent underline">
      weapp-vite & weapp-tailwindcss
    </view>
    <view>
      <HelloWorld
        title="{{hello.title}}"
        description="{{hello.description}}"
        docs="{{hello.docs}}"
        links="{{hello.links}}" />
    </view>
    <view class="flex items-center">
      <text>切换模式</text>
      <view
        class="iconify {{ mode === 'light' ? 'i-mdi-moon-waxing-crescent':'i-mdi-weather-sunny text-white' }} text-4xl"></view>
    </view>
    <view class="underline" mark:url="https://vite.icebreaker.top">
      https://vite.icebreaker.top
    </view>
    <view class="underline" mark:url="https://tw.icebreaker.top/">https://tw.icebreaker.top/</view>
    <button
      activity-type="0"
      entrance-path=""
      need-show-entrance=""
      class="rounded-full bg-sky-600 px-6 py-2 text-white">
      打开布局演示页
    </button>
  </view>
</view>
"
`;

exports[`template e2e: weapp-vite-tailwindcss-template > renders all pages from app config > weapp-vite-tailwindcss-template::pages/layouts/index 1`] = `
"<view class="min-h-screen bg-slate-100 px-4 py-5">
  <view
    class="rounded-2xl border border-sky-200 bg-linear-to-br from-sky-50 to-white p-5 shadow-sm">
    <view class="text-xs font-semibold uppercase tracking-_b0_d2em_B text-sky-700">
      Native Layouts
    </view>
    <view class="mt-3 text-2xl font-bold text-slate-900">Tailwind 原生模板已接入 layouts</view>
    <view class="mt-3 text-sm leading-7 text-slate-600">当前状态：{{currentLayout}}</view>
  </view>

  <view
    wx:for="{{cards}}"
    wx:key="title"
    class="mt-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <view class="text-lg font-bold text-slate-900">{{item.title}}</view>
    <view class="mt-3 text-sm leading-7 text-slate-600">{{item.desc}}</view>
  </view>

  <view class="mt-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <button
      activity-type="0"
      entrance-path=""
      need-show-entrance=""
      class="_emt-0 rounded-full bg-slate-900 text-white">
      使用 default 布局
    </button>
    <button
      activity-type="0"
      entrance-path=""
      need-show-entrance=""
      class="mt-3 rounded-full bg-emerald-600 text-white">
      切到 admin 布局
    </button>
    <button
      activity-type="0"
      entrance-path=""
      need-show-entrance=""
      class="mt-3 rounded-full bg-slate-200 text-slate-900">
      关闭布局
    </button>
    <button
      activity-type="0"
      entrance-path=""
      need-show-entrance=""
      class="mt-3 rounded-full bg-sky-100 text-sky-700">
      返回首页
    </button>
  </view>
</view>
"
`;

