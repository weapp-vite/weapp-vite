// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`template e2e: weapp-vite-template > renders all pages from app config in cjs > weapp-vite-template::app.wxss 1`] = `
"/* empty */
"
`;

exports[`template e2e: weapp-vite-template > renders all pages from app config in cjs > weapp-vite-template::pages/index/index 1`] = `
"<weapp-layout-default __wvSlotOwnerId="{{__wvSlotOwnerId || __wvOwnerId || ''}}">
  <view class="page">
    <view style="display: flex; align-items: center; justify-content: center">
      <view>
        <image style="width: 200px; height: 190px" src="/logo.png" />
        <view>Hello World From Weapp-vite!</view>
      </view>
    </view>
    <HelloWorld
      title="{{hello.title}}"
      description="{{hello.description}}"
      docs="{{hello.docs}}"
      links="{{hello.links}}" />
    <view style="padding: 24rpx 32rpx 48rpx">
      <button activity-type="0" entrance-path="" need-show-entrance="">打开布局演示页</button>
    </view>
  </view>
</weapp-layout-default>
"
`;

exports[`template e2e: weapp-vite-template > renders all pages from app config in cjs > weapp-vite-template::pages/layouts/index 1`] = `
"<block wx:if="{{__wv_page_layout_name === 'admin'}}">
  <weapp-layout-admin
    __wvSlotOwnerId="{{__wvSlotOwnerId || __wvOwnerId || ''}}"
    title="{{(__wv_page_layout_props&&__wv_page_layout_props.title)}}"
    subtitle="{{(__wv_page_layout_props&&__wv_page_layout_props.subtitle)}}">
    <view class="page">
      <view class="hero">
        <view class="hero__eyebrow">Native Layouts</view>
        <view class="hero__title">基础模板已接入 layouts</view>
        <view class="hero__desc">当前状态：{{currentLayout}}</view>
      </view>

      <view wx:for="{{cards}}" wx:key="title" class="section">
        <view class="section-title">{{item.title}}</view>
        <view class="section-desc">{{item.desc}}</view>
      </view>

      <view class="section">
        <button activity-type="0" entrance-path="" need-show-entrance="" class="action-btn">
          使用 default 布局
        </button>
        <button
          activity-type="0"
          entrance-path=""
          need-show-entrance=""
          class="action-btn action-btn--primary">
          切到 admin 布局
        </button>
        <button
          activity-type="0"
          entrance-path=""
          need-show-entrance=""
          class="action-btn action-btn--ghost">
          关闭布局
        </button>
        <button
          activity-type="0"
          entrance-path=""
          need-show-entrance=""
          class="action-btn action-btn--light">
          返回首页
        </button>
      </view>
    </view>
  </weapp-layout-admin>
</block>
<block wx:elif="{{!__wv_page_layout_name || __wv_page_layout_name === 'default'}}">
  <weapp-layout-default
    __wvSlotOwnerId="{{__wvSlotOwnerId || __wvOwnerId || ''}}"
    title="{{(__wv_page_layout_props&&__wv_page_layout_props.title)}}"
    subtitle="{{(__wv_page_layout_props&&__wv_page_layout_props.subtitle)}}">
    <view class="page">
      <view class="hero">
        <view class="hero__eyebrow">Native Layouts</view>
        <view class="hero__title">基础模板已接入 layouts</view>
        <view class="hero__desc">当前状态：{{currentLayout}}</view>
      </view>

      <view wx:for="{{cards}}" wx:key="title" class="section">
        <view class="section-title">{{item.title}}</view>
        <view class="section-desc">{{item.desc}}</view>
      </view>

      <view class="section">
        <button activity-type="0" entrance-path="" need-show-entrance="" class="action-btn">
          使用 default 布局
        </button>
        <button
          activity-type="0"
          entrance-path=""
          need-show-entrance=""
          class="action-btn action-btn--primary">
          切到 admin 布局
        </button>
        <button
          activity-type="0"
          entrance-path=""
          need-show-entrance=""
          class="action-btn action-btn--ghost">
          关闭布局
        </button>
        <button
          activity-type="0"
          entrance-path=""
          need-show-entrance=""
          class="action-btn action-btn--light">
          返回首页
        </button>
      </view>
    </view>
  </weapp-layout-default>
</block>
<block wx:else>
  <view class="page">
    <view class="hero">
      <view class="hero__eyebrow">Native Layouts</view>
      <view class="hero__title">基础模板已接入 layouts</view>
      <view class="hero__desc">当前状态：{{currentLayout}}</view>
    </view>

    <view wx:for="{{cards}}" wx:key="title" class="section">
      <view class="section-title">{{item.title}}</view>
      <view class="section-desc">{{item.desc}}</view>
    </view>

    <view class="section">
      <button activity-type="0" entrance-path="" need-show-entrance="" class="action-btn">
        使用 default 布局
      </button>
      <button
        activity-type="0"
        entrance-path=""
        need-show-entrance=""
        class="action-btn action-btn--primary">
        切到 admin 布局
      </button>
      <button
        activity-type="0"
        entrance-path=""
        need-show-entrance=""
        class="action-btn action-btn--ghost">
        关闭布局
      </button>
      <button
        activity-type="0"
        entrance-path=""
        need-show-entrance=""
        class="action-btn action-btn--light">
        返回首页
      </button>
    </view>
  </view>
</block>
"
`;

