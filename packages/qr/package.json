{
  "name": "@weapp-vite/qr",
  "type": "module",
  "version": "1.0.0",
  "description": "weapp-vite 生态二维码编码、解码与终端渲染工具包",
  "author": "ice breaker <1324318532@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/weapp-vite/weapp-vite",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weapp-vite/weapp-vite.git",
    "directory": "packages/qr"
  },
  "bugs": {
    "url": "https://github.com/weapp-vite/weapp-vite/issues"
  },
  "keywords": [
    "weapp-vite",
    "qr",
    "qrcode",
    "terminal",
    "decode",
    "encode"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
