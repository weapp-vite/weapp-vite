{
  "name": "@wevu/api",
  "type": "module",
  "version": "0.1.1",
  "description": "tsdown bundler template",
  "author": "ice breaker <1324318532@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weapp-vite/weapp-vite.git",
    "directory": "packages/weapi"
  },
  "bugs": {
    "url": "https://github.com/weapp-vite/weapp-vite/issues"
  },
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": {
        "types": "./types/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./types/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./types/index.d.ts",
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "dev": "tsdown -w",
    "build": "tsdown",
    "test": "vitest run",
    "test:dev": "vitest",
    "test:types": "tsd",
    "release": "pnpm publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "catalog:sync": "node ./scripts/sync-api-catalog.mjs",
    "catalog:check": "node ./scripts/sync-api-catalog.mjs --check",
    "strict-alias:check": "node --import tsx ./scripts/check-strict-alias-guard.mjs",
    "structure:check": "node ./scripts/check-structure-guard.mjs",
    "strict-alias:scan": "node --import tsx ./scripts/scan-strict-alias-candidates.mjs",
    "docs:sync": "node --import tsx ./scripts/sync-support-matrix.ts",
    "docs:check": "node --import tsx ./scripts/sync-support-matrix.ts --check",
    "report:api": "node --import tsx ./scripts/generate-api-report.mjs",
    "prebuild": "pnpm run structure:check && pnpm run typecheck && pnpm run typecheck:test && pnpm run catalog:check && pnpm run docs:check && pnpm run strict-alias:check",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@douyin-microapp/typings": "^1.3.1",
    "@mini-types/alipay": "catalog:",
    "miniprogram-api-typings": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
