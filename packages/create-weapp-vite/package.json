{
  "name": "create-weapp-vite",
  "type": "module",
  "version": "2.3.1",
  "description": "create-weapp-vite",
  "author": "ice breaker <1324318532@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weapp-vite/weapp-vite.git",
    "directory": "packages/create-weapp-vite"
  },
  "bugs": {
    "url": "https://github.com/weapp-vite/weapp-vite/issues"
  },
  "keywords": [
    "weapp-vite",
    "vite",
    "weapp"
  ],
  "sideEffects": false,
  "weapp-vite-dev": {
    "exports": {
      ".": "./src/index.ts"
    },
    "main": "./src/index.ts",
    "module": "./src/index.ts",
    "types": "./src/index.ts",
    "bin": "./dev/bin.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": "./bin/create-weapp-vite.js",
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "catalog:sync": "node --import tsx scripts/generate-template-catalog.ts",
    "dev": "tsdown -w --sourcemap",
    "build": "tsdown",
    "prepack": "node --import tsx scripts/prepublish.ts && pnpm build",
    "test": "vitest run",
    "test:dev": "vitest",
    "pretest:types": "pnpm build",
    "test:types": "tsd",
    "typecheck": "tsc --noEmit",
    "release": "pnpm publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": "./bin/create-weapp-vite.js"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "@weapp-core/logger": "workspace:^",
    "@weapp-core/shared": "workspace:^",
    "pathe": "catalog:",
    "pkg-types": "catalog:"
  }
}
