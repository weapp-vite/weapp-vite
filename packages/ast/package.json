{
  "name": "@weapp-vite/ast",
  "type": "module",
  "version": "6.8.0",
  "description": "weapp-vite 共享 AST 分析工具包，统一 Babel/Oxc 解析与常用分析操作",
  "author": "ice breaker <1324318532@qq.com>",
  "license": "MIT",
  "homepage": "https://vite.icebreaker.top/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weapp-vite/weapp-vite.git",
    "directory": "packages/ast"
  },
  "bugs": {
    "url": "https://github.com/weapp-vite/weapp-vite/issues"
  },
  "keywords": [
    "ast",
    "babel",
    "oxc",
    "weapp-vite",
    "compiler",
    "analysis"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./babel": {
      "types": "./dist/babel.d.mts",
      "import": {
        "types": "./dist/babel.d.mts",
        "default": "./dist/babel.mjs"
      }
    },
    "./engine": {
      "types": "./dist/engine.d.mts",
      "import": {
        "types": "./dist/engine.d.mts",
        "default": "./dist/engine.mjs"
      }
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "import": {
        "types": "./dist/types.d.mts",
        "default": "./dist/types.mjs"
      }
    },
    "./operations/platformApi": {
      "types": "./dist/operations/platformApi.d.mts",
      "import": {
        "types": "./dist/operations/platformApi.d.mts",
        "default": "./dist/operations/platformApi.mjs"
      }
    },
    "./operations/require": {
      "types": "./dist/operations/require.d.mts",
      "import": {
        "types": "./dist/operations/require.d.mts",
        "default": "./dist/operations/require.mjs"
      }
    },
    "./operations/scriptSetupImports": {
      "types": "./dist/operations/scriptSetupImports.d.mts",
      "import": {
        "types": "./dist/operations/scriptSetupImports.d.mts",
        "default": "./dist/operations/scriptSetupImports.mjs"
      }
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown -w",
    "build": "tsdown",
    "test": "vitest run",
    "test:dev": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "pnpm publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@babel/generator": "catalog:",
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "@babel/types": "catalog:",
    "@oxc-project/types": "^0.119.0",
    "oxc-parser": "^0.119.0",
    "oxc-walker": "^0.7.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
