{
  "name": "weapp-vite",
  "type": "module",
  "version": "6.8.0",
  "description": "weapp-vite 一个现代化的小程序打包工具",
  "author": "ice breaker <1324318532@qq.com>",
  "license": "MIT",
  "homepage": "https://vite.icebreaker.top/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weapp-vite/weapp-vite.git",
    "directory": "packages/weapp-vite"
  },
  "bugs": {
    "url": "https://github.com/weapp-vite/weapp-vite/issues"
  },
  "keywords": [
    "weapp",
    "vite",
    "ts",
    "wxml",
    "wxss",
    "mp",
    "miniprogram",
    "scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.mjs"
    },
    "./json": {
      "types": "./dist/json.d.ts",
      "import": "./dist/json.mjs"
    },
    "./volar": {
      "types": "./dist/volar.d.ts",
      "import": "./dist/volar.mjs",
      "require": "./volar.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.mjs"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.mjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs"
    },
    "./auto-import-components/resolvers": {
      "types": "./dist/auto-import-components/resolvers.d.ts",
      "import": "./dist/auto-import-components/resolvers.mjs"
    },
    "./auto-routes": {
      "types": "./dist/auto-routes.d.ts",
      "import": "./dist/auto-routes.mjs"
    },
    "./client": {
      "types": "./client.d.ts"
    },
    "./package.json": "./package.json",
    "./*": "./*"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "weapp-vite": "bin/weapp-vite.js",
    "wv": "bin/weapp-vite.js"
  },
  "files": [
    "bin",
    "client.d.ts",
    "dist",
    "modules",
    "volar.cjs"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "stub": "unbuild --stub",
    "dev": "tsdown -w --sourcemap",
    "build": "pnpm run build:dashboard && tsdown",
    "build:dashboard": "node scripts/build-analyze-dashboard.mjs",
    "dev:dashboard": "vite --config analyze-dashboard/vite.config.ts",
    "preview:dashboard": "vite preview --config analyze-dashboard/vite.config.ts",
    "release": "tsx scripts/release.ts",
    "bench": "vitest bench -c vitest.bench.config.ts",
    "test:dev": "vitest",
    "test": "vitest run",
    "test:types": "cd test-d/auto-routes-define-app-json && tsd",
    "typecheck": "tsc --noEmit",
    "sync": "cnpm sync weapp-vite"
  },
  "dependencies": {
    "@volar/typescript": "^2.4.28",
    "@vue/compiler-core": "catalog:",
    "@vue/language-core": "catalog:",
    "@weapp-core/init": "workspace:*",
    "@weapp-core/logger": "workspace:*",
    "@weapp-core/schematics": "workspace:*",
    "@weapp-core/shared": "workspace:*",
    "@weapp-vite/ast": "workspace:*",
    "@weapp-vite/mcp": "workspace:*",
    "@weapp-vite/volar": "workspace:*",
    "@weapp-vite/web": "workspace:*",
    "@wevu/api": "workspace:*",
    "comment-json": "catalog:",
    "debug": "catalog:",
    "fdir": "catalog:",
    "fs-extra": "catalog:",
    "magic-string": "catalog:",
    "pathe": "catalog:",
    "picomatch": "^4.0.3",
    "postcss": "catalog:",
    "rolldown": "1.0.0-rc.9",
    "rolldown-plugin-dts": "0.22.5",
    "rolldown-require": "workspace:*",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-performance": "workspace:*",
    "vite-tsconfig-paths": "^6.1.1",
    "vue": "catalog:",
    "vue-tsc": "catalog:",
    "weapp-ide-cli": "workspace:*",
    "wevu": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/semver": "catalog:",
    "@vitejs/plugin-vue": "^6.0.5",
    "bundle-require": "catalog:",
    "cac": "^7.0.0",
    "chokidar": "^5.0.0",
    "del": "^8.0.1",
    "echarts": "catalog:",
    "esbuild": "catalog:",
    "estree-walker": "catalog:",
    "htmlparser2": "catalog:",
    "local-pkg": "^1.1.2",
    "lru-cache": "catalog:",
    "magic-string": "catalog:",
    "oxc-parser": "^0.119.0",
    "oxc-walker": "^0.7.0",
    "p-queue": "^9.1.0",
    "package-manager-detector": "^1.6.0",
    "resolve.exports": "^2.0.3",
    "rimraf": "6.1.3",
    "semver": "^7.7.4",
    "tailwindcss": "catalog:tailwind4",
    "ts-morph": "catalog:",
    "vue": "^3.5.26"
  }
}
