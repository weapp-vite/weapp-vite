{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.test.tsbuildinfo",
    "target": "ESNext",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "resolveJsonModule": true,
    "types": [
      "vitest/globals",
      "vite/client",
      "vue/jsx"
    ],
    "allowArbitraryExtensions": true,
    "strict": true,
    "declaration": true,
    "noEmit": false,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "test/**/*.test.ts",
    "test/**/*.spec.ts",
    "client.d.ts"
  ],
  "exclude": [
    "coverage",
    "dist",
    "node_modules"
  ]
}
