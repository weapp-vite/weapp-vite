{
  "name": "simulator",
  "type": "module",
  "version": "0.0.0",
  "description": "Headless mini-program runtime and testing kernel for the weapp-vite ecosystem",
  "author": "ice breaker <1324318532@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weapp-vite/weapp-vite.git",
    "directory": "mpcore/packages/simulator"
  },
  "bugs": {
    "url": "https://github.com/weapp-vite/weapp-vite/issues"
  },
  "keywords": [
    "weapp",
    "mini-program",
    "runtime",
