  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "tsdown -w",
    "build": "tsdown",
    "test": "vitest run",
    "test:dev": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "htmlparser2": "catalog:",
    "pathe": "catalog:"
  }
}
