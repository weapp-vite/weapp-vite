<view class="screen">
  <view class="panel-row">{{title}}</view>
  <view class="panel-row">Count: {{count}}</view>
  <view class="panel-row">Status: {{status}}</view>
  <view class="panel-row">Observer: {{observerLog}}</view>
  <view class="panel-row">Clicks: {{internalClicks}}</view>
  <mini-badge id="mini-badge" label="{{status}}" />
  <view class="panel-row" id="status-card-pulse" data-phase="pulse" data-card="status" bindtap="pulse">组件内部触发 pulse</view>
  <view class="panel-row" bindtap="inspectNested">组件内部查询子组件</view>
  <view class="panel-row">Nested: {{nestedBadge}}</view>
</view>
