<view class="screen">
  <view class="headline">{{title}}</view>
  <view class="panel-row" bindtap="promote">页面自己加一档</view>
  <view
    wx:for="{{quickActions}}"
    wx:key="status"
    wx:for-item="action"
    class="panel-row"
    data-status="{{action.status}}"
    catchtap="applyStatus"
  >
    {{action.label}}
  </view>
  <view class="panel-row" bindtap="toggleMeta">切换 meta 区块</view>
  <view class="panel-row" bindtap="inspectCard">检查组件实例</view>
  <view class="panel-row" bindtap="inspectCompoundCard">检查复合组件选择器</view>
  <view class="panel-row" bindtap="inspectScopedComponentQuery">检查组件作用域 SelectorQuery</view>
  <view class="panel-row" bindtap="runVideoContextLab">检查 VideoContext</view>
  <view class="panel-row" bindtap="runIntersectionObserverLab">检查 IntersectionObserver</view>
  <view class="panel-row" bindtap="runMediaQueryObserverLab">检查 MediaQueryObserver</view>
  <view class="panel-row" bindtap="runAnimationLab">检查 Animation</view>
  <view class="panel-row" bindtap="runCanvasLab">检查 CanvasContext</view>
  <view class="panel-row" bindtap="inspectCanvasQuery">检查 Canvas SelectorQuery context</view>
  <view class="panel-row" bindtap="loadMockQueue">调用 request mock</view>
  <view class="panel-row" bindtap="storeSnapshot">写入 storage</view>
  <view class="panel-row" bindtap="toastSnapshot">触发 toast</view>
  <view class="panel-row" data-phase="outer-bind" bindtap="recordTap">
    外层 bind 区域
    <view class="panel-row" id="tap-bind-chain" data-phase="inner-bind" bindtap="recordTap">点击这里应触发 inner-bind -> outer-bind</view>
    <view class="panel-row" id="tap-catch-chain" data-phase="inner-catch" catchtap="recordTap">点击这里应只触发 inner-catch</view>
  </view>
  <status-card
    class="primary-card"
    data-role="main"
    id="status-card"
    title="{{cardTitle}}"
    count="{{count}}"
    status="{{status}}"
    bind:pulse="handlePulse"
  />
  <view wx:if="{{flags.showMeta}}" class="panel-row">最近事件：{{events.0}}</view>
  <view wx:elif="{{eventShape}}" class="panel-row">meta 已隐藏，但保留事件形态</view>
  <view wx:else class="panel-row">meta 已隐藏且还没有事件</view>
  <view class="panel-row">事件形态：{{eventShape}}</view>
  <view class="panel-row">组件快照：{{componentSnapshot}}</view>
  <view class="panel-row">复合组件快照：{{compoundComponentSnapshot}}</view>
  <view class="panel-row">组件作用域查询：{{scopedComponentRect}}</view>
  <view id="observer-card" class="panel-row" style="left: 18px; top: 24px; width: 96px; height: 32px;">observer target</view>
  <view class="panel-row">Observer 快照：{{intersectionObserverSnapshot}}</view>
  <view class="panel-row">MediaQuery 快照：{{mediaQueryObserverSnapshot}}</view>
  <view class="panel-row">Animation 快照：{{animationSnapshot}}</view>
  <view class="panel-row">Canvas 快照：{{canvasSnapshot}}</view>
  <view class="panel-row">Canvas Query 快照：{{canvasQuerySnapshot}}</view>
  <canvas canvas-id="lab-canvas"></canvas>
  <video
    id="lab-video"
    bindplay="handleVideoPlay"
    bindpause="handleVideoPause"
    bindfullscreenchange="handleVideoFullscreen"
  />
  <view class="panel-row">Video 快照：{{videoContextSnapshot}}</view>
  <view class="panel-row">请求快照：{{requestSnapshot}}</view>
  <view class="panel-row">存储快照：{{storageSnapshot}}</view>
  <view class="panel-row">Toast 状态：{{toastState}}</view>
  <view class="panel-row">点击链：{{tapTrail.0}} -> {{tapTrail.1}}</view>
  <view class="panel-row">最近轨迹：{{traces.0}}</view>
</view>
