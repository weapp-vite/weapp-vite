<view class="screen">
  <view class="headline">{{title}}</view>
  <view class="panel-row" bindtap="openAsset">打开素材详情</view>
  <view class="panel-row" bindtap="relaunchReview">reLaunch 到审核页</view>
  <view class="panel-row" bindtap="backToEditor">返回编辑页</view>
  <view class="panel-row">Entry: {{entry}}</view>
  <view class="panel-row">Featured asset: {{assets.1.label}}</view>
  <view class="panel-row">Trace: {{logs.0}}</view>
</view>
