.package-hero {
  padding: 32rpx;
  color: #10324a;
  background: #dff6ff;
  border-radius: 24rpx;
}

.package-hero__title {
  font-size: 38rpx;
  font-weight: 700;
}

.package-hero__desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.package-hero__size {
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 28rpx;
}

.event-row {
  padding: 22rpx;
  font-size: 25rpx;
  line-height: 1.5;
  background: #fff;
  border-radius: 18rpx;
}
