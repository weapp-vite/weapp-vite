{
  "name": "wevu-vue-sfc-recording-demo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "description": "wevu + Vue SFC 录屏演示项目",
  "scripts": {
    "prepare:weapp": "wv prepare",
    "dev": "wv dev",
    "dev:open": "wv dev -o",
    "build": "wv build",
    "typecheck": "vue-tsc --noEmit -p .weapp-vite/tsconfig.app.json",
    "open": "wv open",
    "video:prepare": "bash ../../docs/recording/wevu-vue-sfc-recording-demo/export-ppt-video.sh",
    "postinstall": "weapp-tw patch && wv prepare",
    "dev:ui": "wv dev --ui",
    "build:ui": "wv build --ui"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@weapp-vite/dashboard": "workspace:*",
    "miniprogram-api-typings": "catalog:",
    "tailwindcss": "catalog:tailwind4",
    "typescript": "catalog:",
    "vue-tsc": "catalog:",
    "weapp-tailwindcss": "catalog:",
    "weapp-vite": "workspace:*",
    "wevu": "workspace:*"
  }
}
