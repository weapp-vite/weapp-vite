{
  "name": "wevu-vue-sfc-recording-demo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "description": "wevu + Vue SFC 录屏演示项目",
  "scripts": {
    "prepare:weapp": "weapp-vite prepare",
    "dev": "weapp-vite dev",
    "dev:open": "weapp-vite dev -o",
    "build": "weapp-vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "open": "weapp-vite open",
    "video:prepare": "bash ../../docs/recording/wevu-vue-sfc-recording-demo/export-ppt-video.sh",
    "postinstall": "weapp-tw patch && weapp-vite prepare"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "miniprogram-api-typings": "catalog:",
    "tailwindcss": "catalog:tailwind4",
    "typescript": "catalog:",
    "vue-tsc": "catalog:",
    "weapp-tailwindcss": "catalog:",
    "weapp-vite": "workspace:*",
    "wevu": "workspace:*"
  }
}
