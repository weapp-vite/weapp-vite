{
  "name": "wevu-vue-demo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev": "weapp-vite dev",
    "dev:open": "weapp-vite dev -o",
    "build": "weapp-vite build",
    "gen:api-list": "node scripts/gen-miniprogram-api.js",
    "typecheck": "vue-tsc --noEmit -p .weapp-vite/tsconfig.app.json",
    "open": "weapp-vite open",
    "postinstall": "weapp-vite prepare",
    "dev:ui": "weapp-vite dev --ui",
    "build:ui": "weapp-vite build --ui"
  },
  "devDependencies": {
    "@weapp-core/schematics": "workspace:*",
    "@weapp-vite/dashboard": "workspace:*",
    "@weapp-vite/volar": "workspace:*",
    "miniprogram-api-typings": "catalog:latest",
    "typescript": "catalog:latest",
    "weapp-vite": "workspace:*",
    "wevu": "workspace:*"
  },
  "dependenciesMeta": {
    "weapp-vite": {
      "injected": true
    }
  }
}
