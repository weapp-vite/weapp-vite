.vchart {
  position: relative;
  width: 100%;
  height: 100%;
  padding: 0!important;
}

.cs-canvas {
  display: block;
  width: 100%;
  height: 100%;
  margin: 0;
}

.cs-canvas-hidden {
  display: none;
  visibility: hidden;
  opacity: 0;
}

.cs-tooltip-canvas {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
  width: 100%;
  height: 100%;
  pointer-events: none;
}
