  "scripts": {
    "prepare:weapp": "weapp-vite prepare",
    "dev": "weapp-vite dev -p weapp",
    "dev:open": "weapp-vite dev -p weapp -o",
    "dev:weapp": "weapp-vite dev -p weapp",
    "dev:alipay": "weapp-vite dev -p alipay",
    "dev:alipay:open": "weapp-vite dev -p alipay -o",
    "dev:tt": "weapp-vite dev -p tt",
    "dev:swan": "weapp-vite dev -p swan",
    "dev:jd": "weapp-vite dev -p jd",
    "dev:xhs": "weapp-vite dev -p xhs",
    "dev:web": "weapp-vite dev -p h5 --host",
    "build": "weapp-vite build -p weapp",
    "build:weapp": "weapp-vite build -p weapp",
    "build:alipay": "weapp-vite build -p alipay",
    "build:tt": "weapp-vite build -p tt",
    "build:swan": "weapp-vite build -p swan",
    "build:jd": "weapp-vite build -p jd",
    "build:xhs": "weapp-vite build -p xhs",
    "build:web": "weapp-vite build -p h5",
    "typecheck": "vue-tsc --noEmit -p .weapp-vite/tsconfig.app.json",
    "open": "weapp-vite open",
    "postinstall": "weapp-tw patch && weapp-vite prepare",
    "dev:ui": "weapp-vite dev --ui -p weapp",
    "build:ui": "weapp-vite build --ui -p weapp"
