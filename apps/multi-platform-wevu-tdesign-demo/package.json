    "postcss": "catalog:",
    "sass": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vue-tsc": "catalog:",
    "weapp-tailwindcss": "catalog:",
    "weapp-vite": "workspace:*",
    "wevu": "workspace:*"
  },
  "dependenciesMeta": {
