<view class="page">
  <view class="panel">
    <view class="title">{{title}}</view>
    <view class="description">{{description}}</view>
    <view class="meta">{{lastActionAt}}</view>
  </view>

  <view class="panel">
    <view class="section-title">检查点</view>
    <view wx:for="{{checkpoints}}" wx:key="key" class="checkpoint">
      <view class="checkpoint-title">{{index + 1}}. {{item.title}}</view>
      <view class="checkpoint-tool">Tool: {{item.tool}}</view>
      <view class="checkpoint-expected">预期: {{item.expected}}</view>
    </view>
  </view>

  <view class="panel">
    <view class="section-title">快捷命令</view>
    <view wx:for="{{commands}}" wx:key="name" class="command-item">
      <view class="command-name">{{item.name}}</view>
      <view class="command-value">{{item.command}}</view>
      <button
        class="copy-btn"
        size="mini"
        data-command="{{item.command}}"
        bind:tap="onCopyCommand"
      >
        复制命令
      </button>
    </view>
  </view>

  <view class="panel">
    <view class="section-title">测试提示词</view>
    <view class="prompt">{{promptText}}</view>
    <button class="copy-prompt-btn" bind:tap="onCopyPrompt">复制提示词</button>
  </view>

  <view id="mcp-runtime-root" class="panel mcp-runtime-root" data-role="runtime-root">
    <view class="section-title">交互探针</view>
    <view id="mcp-tap-counter" class="probe-value">tapCounter = {{tapCounter}}</view>
    <button id="mcp-tap-button" class="probe-btn" bind:tap="onTapCounter">点击 +1</button>
    <input
      id="mcp-input"
      class="probe-input"
      value="{{inputValue}}"
      placeholder="MCP input"
      bindinput="onProbeInput"
    />
    <view id="mcp-input-value" class="probe-value">inputValue = {{inputValue}}</view>
    <view id="mcp-page-state" class="probe-value">mcpStatus = {{mcpStatus}}</view>
    <scroll-view id="mcp-scroll" class="probe-scroll" scroll-y scroll-x>
      <view class="probe-scroll-content">
        <view wx:for="{{checkpoints}}" wx:key="key" class="probe-scroll-item">
          {{item.title}}
        </view>
      </view>
    </scroll-view>
    <mcp-probe id="mcp-component" class="probe-component">
      <view class="component-child">组件子节点</view>
    </mcp-probe>
  </view>
</view>
