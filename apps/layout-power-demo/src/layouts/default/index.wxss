.theme-layout {
  position: relative;
  min-height: 100vh;
  padding: 0 28rpx 28rpx;
  overflow: hidden;
  background: #eef6ff;
  animation: theme-enter 220ms ease-out both;
}

.theme-layout__transition {
  position: absolute;
  top: 0;
  bottom: 0;
  left: -42%;
  z-index: 3;
  width: 76%;
  pointer-events: none;
  background: linear-gradient(90deg, transparent, #fff 18%, #2563eb 74%, transparent);
  transform: skewX(-14deg);
  animation: theme-wipe 520ms cubic-bezier(0.18, 0.9, 0.22, 1) both;
}

.theme-layout__navbar {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  color: #12325f;
}

.theme-layout__navbar,
.theme-layout__nav,
.theme-layout__content,
.theme-layout__globals {
  position: relative;
  z-index: 1;
}

.theme-layout__navbar-text,
.theme-layout__navbar-theme,
.theme-layout__kicker,
.theme-layout__title,
.theme-layout__mode,
.theme-layout__safe-area {
  display: block;
}

.theme-layout__navbar-title {
  display: flex;
  flex: 1;
  gap: 10rpx;
  align-items: center;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 900;
}

.theme-layout__navbar-dot {
  width: 14rpx;
  height: 14rpx;
  background: #2563eb;
  border-radius: 50%;
}

.theme-layout__navbar-theme {
  box-sizing: border-box;
  width: var(--demo-navbar-capsule-width, 176rpx);
  height: var(--demo-navbar-capsule-height, 64rpx);
  padding: 0 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 20rpx;
  font-weight: 900;
  line-height: var(--demo-navbar-capsule-height, 64rpx);
  color: #fff;
  text-align: center;
  white-space: nowrap;
  background: #2563eb;
  border-radius: 6rpx;
}

.theme-layout__nav {
  box-sizing: border-box;
  display: flex;
  gap: 18rpx;
  align-items: center;
  justify-content: space-between;
  height: 108rpx;
  padding: 22rpx 26rpx;
  color: #12325f;
  background: #fff;
  border: 1rpx solid #b9d8ff;
  border-radius: 8rpx;
  box-shadow: 0 16rpx 34rpx rgb(37 99 235 / 14%);
}

.theme-layout__brand {
  flex: 1;
  min-width: 0;
}

.theme-layout__kicker {
  font-size: 22rpx;
  font-weight: 900;
  color: #2563eb;
  text-transform: uppercase;
}

.theme-layout__title {
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.12;
  white-space: nowrap;
}

.theme-layout__mode {
  max-width: 230rpx;
  padding: 10rpx 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 22rpx;
  font-weight: 900;
  color: #fff;
  white-space: nowrap;
  background: #2563eb;
  border-radius: 6rpx;
}

.theme-layout__default-stack {
  box-sizing: border-box;
  display: grid;
  gap: 10rpx;
  align-content: center;
  width: 132rpx;
  height: 64rpx;
  padding: 12rpx;
  background: #eef6ff;
  border: 1rpx solid #b9d8ff;
  border-radius: 8rpx;
}

.theme-layout__default-line {
  width: 92rpx;
  height: 12rpx;
  background: #2563eb;
  border-radius: 999rpx;
}

.theme-layout__default-line--short {
  width: 54rpx;
  background: #9cc8ff;
}

.theme-layout__content {
  margin-top: 20rpx;
}

.theme-layout__globals {
  display: flex;
  gap: 12rpx;
  align-items: center;
  justify-content: flex-end;
  height: 52rpx;
  margin-top: 18rpx;
  color: #12325f;
}

.theme-layout__safe-area {
  padding: 8rpx 12rpx;
  font-size: 22rpx;
  font-weight: 900;
  background: #fff;
  border: 1rpx solid #b9d8ff;
  border-radius: 6rpx;
}

@keyframes theme-enter {
  from {
    opacity: 0.94;
  }

  to {
    opacity: 1;
  }
}

@keyframes theme-wipe {
  0% {
    opacity: 0;
    transform: translateX(-80%) skewX(-14deg);
  }

  18% {
    opacity: 0.95;
  }

  100% {
    opacity: 0;
    transform: translateX(230%) skewX(-14deg);
  }
}
