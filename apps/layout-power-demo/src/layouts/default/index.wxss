.default-layout {
  display: flex;
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #e5edf6 100%);
}

.default-layout__rail {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  background: #d7dee8;
}

.default-layout__rail-text {
  width: 260rpx;
  font-size: 20rpx;
  color: #42526b;
  text-align: center;
  transform: rotate(-90deg);
}

.default-layout__body {
  flex: 1;
  min-width: 0;
}
