.theme-layout {
  position: relative;
  min-height: 100vh;
  padding: 0 28rpx 28rpx;
  overflow: hidden;
  background: #090d1f;
  animation: theme-enter 220ms ease-out both;
}

.theme-layout__transition {
  position: absolute;
  top: 0;
  bottom: 0;
  left: -42%;
  z-index: 3;
  width: 76%;
  pointer-events: none;
  background: linear-gradient(90deg, transparent, #00e5ff 18%, #ff4fd8 72%, transparent);
  transform: skewX(-14deg);
  animation: theme-wipe 520ms cubic-bezier(0.18, 0.9, 0.22, 1) both;
}

.theme-layout__navbar {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  color: #b9f7ff;
}

.theme-layout__navbar,
.theme-layout__nav,
.theme-layout__content,
.theme-layout__globals {
  position: relative;
  z-index: 1;
}

.theme-layout__navbar-text,
.theme-layout__prompt,
.theme-layout__cursor,
.theme-layout__kicker,
.theme-layout__title,
.theme-layout__mode,
.theme-layout__toast {
  display: block;
}

.theme-layout__navbar-title {
  display: flex;
  flex: 1;
  gap: 8rpx;
  align-items: center;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 900;
}

.theme-layout__prompt {
  width: 32rpx;
  height: 32rpx;
  font-size: 28rpx;
  line-height: 32rpx;
  color: #090d1f;
  text-align: center;
  background: #00e5ff;
  border-radius: 6rpx;
}

.theme-layout__cursor {
  width: 20rpx;
  height: 30rpx;
  background: #00e5ff;
  box-shadow: 0 0 18rpx rgb(0 229 255 / 62%);
  animation: command-cursor 960ms steps(1, end) infinite;
}

.theme-layout__nav {
  box-sizing: border-box;
  display: flex;
  gap: 18rpx;
  align-items: center;
  justify-content: space-between;
  height: 108rpx;
  padding: 22rpx 26rpx;
  color: #fff;
  background: #171b3a;
  border: 1rpx solid #00e5ff;
  border-radius: 8rpx;
  box-shadow: 0 0 34rpx rgb(0 229 255 / 32%);
}

.theme-layout__brand {
  flex: 1;
  min-width: 0;
}

.theme-layout__kicker {
  font-size: 22rpx;
  font-weight: 900;
  color: #00e5ff;
  text-transform: uppercase;
}

.theme-layout__title {
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.12;
  white-space: nowrap;
}

.theme-layout__mode {
  max-width: 230rpx;
  padding: 10rpx 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 22rpx;
  font-weight: 900;
  color: #090d1f;
  white-space: nowrap;
  background: #ff4fd8;
  border-radius: 6rpx;
}

.theme-layout__command-panel {
  box-sizing: border-box;
  display: grid;
  gap: 7rpx;
  align-content: center;
  width: 154rpx;
  height: 72rpx;
  padding: 9rpx 10rpx;
  background: rgb(0 229 255 / 10%);
  border: 1rpx solid rgb(0 229 255 / 42%);
  border-radius: 8rpx;
}

.theme-layout__terminal-row {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.theme-layout__terminal-dot {
  display: block;
  width: 10rpx;
  height: 10rpx;
  background: rgb(185 247 255 / 58%);
  border-radius: 50%;
}

.theme-layout__terminal-dot--active {
  background: #00e5ff;
  box-shadow: 0 0 12rpx rgb(0 229 255 / 52%);
}

.theme-layout__terminal-dot--warn {
  background: #ff4fd8;
  box-shadow: 0 0 12rpx rgb(255 79 216 / 52%);
}

.theme-layout__terminal-line {
  display: block;
  width: 84rpx;
  height: 8rpx;
  background: rgb(185 247 255 / 64%);
  border-radius: 999rpx;
}

.theme-layout__terminal-line--wide {
  width: 108rpx;
}

.theme-layout__terminal-line--short {
  width: 56rpx;
  background: #ff4fd8;
}

.theme-layout__content {
  margin-top: 20rpx;
}

.theme-layout__globals {
  display: flex;
  gap: 12rpx;
  align-items: center;
  justify-content: flex-end;
  height: 52rpx;
  margin-top: 18rpx;
  color: #b9f7ff;
}

.theme-layout__toast,
.theme-layout__safe-area {
  padding: 8rpx 12rpx;
  font-size: 22rpx;
  font-weight: 900;
  background: rgb(0 229 255 / 12%);
  border: 1rpx solid rgb(0 229 255 / 42%);
  border-radius: 6rpx;
}

@keyframes theme-enter {
  from {
    opacity: 0.94;
  }

  to {
    opacity: 1;
  }
}

@keyframes theme-wipe {
  0% {
    opacity: 0;
    transform: translateX(-80%) skewX(-14deg);
  }

  18% {
    opacity: 0.95;
  }

  100% {
    opacity: 0;
    transform: translateX(230%) skewX(-14deg);
  }
}

@keyframes command-cursor {
  0%,
  48% {
    opacity: 1;
  }

  49%,
  100% {
    opacity: 0.24;
  }
}
