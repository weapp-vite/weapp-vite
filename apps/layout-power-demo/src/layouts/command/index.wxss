.command-layout {
  min-height: 100vh;
  background: linear-gradient(180deg, #101827 0%, #dfe7f1 54%, #eef2f7 100%);
}

.command-layout__nav {
  display: flex;
  gap: 18rpx;
  align-items: center;
  padding: 70rpx 32rpx 22rpx;
  color: #fff;
  background: rgb(16 24 39 / 82%);
}

.command-layout__nav-main {
  flex: 1;
  min-width: 0;
}

.command-layout__nav-kicker,
.command-layout__nav-title {
  display: block;
}

.command-layout__nav-kicker {
  font-size: 22rpx;
  font-weight: 800;
  color: rgb(255 255 255 / 62%);
  text-transform: uppercase;
}

.command-layout__nav-title {
  margin-top: 4rpx;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.15;
}

.command-layout__nav-pill {
  padding: 10rpx 16rpx;
  font-size: 22rpx;
  font-weight: 900;
  color: #101827;
  background: #facc15;
  border-radius: 8rpx;
}

.command-layout__top {
  padding: 28rpx 32rpx 30rpx;
  color: #fff;
}

.command-layout__title-row {
  display: flex;
  gap: 18rpx;
  align-items: center;
}

.command-layout__title {
  flex: 1;
  min-width: 0;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.18;
}

.command-layout__badge {
  max-width: 250rpx;
  padding: 10rpx 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 24rpx;
  font-weight: 900;
  color: #06281f;
  white-space: nowrap;
  background: #34d399;
  border-radius: 8rpx;
}

.command-layout__slots {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
}

.command-layout__slot {
  padding: 10rpx 14rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: rgb(255 255 255 / 86%);
  border: 1rpx solid rgb(255 255 255 / 24%);
  border-radius: 6rpx;
}

.command-layout__body {
  padding: 0 28rpx 28rpx;
}
