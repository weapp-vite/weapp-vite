<view class="theme-layout theme-layout--command" data-layout="command">
  <view class="theme-layout__transition" />

  <view class="theme-layout__navbar" style="{{navbarStyle}}">
    <view class="theme-layout__navbar-title">
      <text class="theme-layout__prompt">&gt;</text>
      <text class="theme-layout__navbar-text">布局演示</text>
      <text class="theme-layout__cursor" />
    </view>
  </view>

  <view class="theme-layout__nav">
    <view class="theme-layout__brand">
      <text class="theme-layout__kicker">外壳</text>
      <text class="theme-layout__title">{{title}}</text>
    </view>
    <view class="theme-layout__command-panel">
      <view class="theme-layout__terminal-row">
        <text class="theme-layout__terminal-dot theme-layout__terminal-dot--active" />
        <text class="theme-layout__terminal-line theme-layout__terminal-line--wide" />
      </view>
      <view class="theme-layout__terminal-row">
        <text class="theme-layout__terminal-dot" />
        <text class="theme-layout__terminal-line" />
      </view>
      <view class="theme-layout__terminal-row">
        <text class="theme-layout__terminal-dot theme-layout__terminal-dot--warn" />
        <text class="theme-layout__terminal-line theme-layout__terminal-line--short" />
      </view>
    </view>
  </view>

  <view class="theme-layout__content">
    <slot />
  </view>

  <view class="theme-layout__globals">
    <text class="theme-layout__mode">{{mode}}</text>
    <text class="theme-layout__toast">命令队列</text>
  </view>
</view>
