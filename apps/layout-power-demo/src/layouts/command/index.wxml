<view class="theme-layout theme-layout--command" data-layout="command">
  <view class="theme-layout__transition" />

  <view class="theme-layout__navbar">
    <view class="theme-layout__navbar-title">
      <text class="theme-layout__signal theme-layout__signal--cyan" />
      <text class="theme-layout__signal theme-layout__signal--pink" />
      <text class="theme-layout__navbar-text">布局演示</text>
    </view>
    <text class="theme-layout__navbar-theme">命令</text>
  </view>

  <view class="theme-layout__nav">
    <view class="theme-layout__brand">
      <text class="theme-layout__kicker">外壳</text>
      <text class="theme-layout__title">{{title}}</text>
    </view>
    <view class="theme-layout__command-panel">
      <text class="theme-layout__meter theme-layout__meter--wide" />
      <text class="theme-layout__meter" />
      <text class="theme-layout__meter theme-layout__meter--short" />
    </view>
  </view>

  <view class="theme-layout__content">
    <slot />
  </view>

  <view class="theme-layout__globals">
    <text class="theme-layout__mode">{{mode}}</text>
    <text class="theme-layout__toast">提示挂载</text>
  </view>
</view>
