.theme-layout {
  position: relative;
  min-height: 100vh;
  padding: 0 28rpx 28rpx;
  overflow: hidden;
  background: #fff0df;
  animation: theme-enter 220ms ease-out both;
}

.theme-layout__transition {
  position: absolute;
  top: 0;
  bottom: 0;
  left: -42%;
  z-index: 3;
  width: 76%;
  pointer-events: none;
  background: linear-gradient(90deg, transparent, #c2410c 18%, #ffe1bc 72%, transparent);
  transform: skewX(-14deg);
  animation: theme-wipe 520ms cubic-bezier(0.18, 0.9, 0.22, 1) both;
}

.theme-layout__navbar {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  color: #251812;
}

.theme-layout__navbar,
.theme-layout__nav,
.theme-layout__content,
.theme-layout__globals {
  position: relative;
  z-index: 1;
}

.theme-layout__navbar-text,
.theme-layout__kicker,
.theme-layout__title,
.theme-layout__mode,
.theme-layout__safe-area {
  display: block;
}

.theme-layout__navbar-title {
  display: flex;
  flex: 1;
  gap: 8rpx;
  align-items: center;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 900;
}

.theme-layout__swatch {
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid #251812;
  border-radius: 4rpx;
}

.theme-layout__swatch--ink {
  background: #251812;
}

.theme-layout__swatch--paper {
  background: #ffe1bc;
}

.theme-layout__nav {
  box-sizing: border-box;
  display: flex;
  gap: 18rpx;
  align-items: center;
  justify-content: space-between;
  height: 108rpx;
  padding: 22rpx 26rpx;
  color: #251812;
  background: #ffe1bc;
  border: 3rpx solid #251812;
  border-radius: 8rpx;
  box-shadow: 10rpx 10rpx 0 #251812;
}

.theme-layout__brand {
  flex: 1;
  min-width: 0;
}

.theme-layout__kicker {
  font-size: 22rpx;
  font-weight: 900;
  color: #c2410c;
  text-transform: uppercase;
}

.theme-layout__title {
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.12;
  white-space: nowrap;
}

.theme-layout__mode {
  max-width: 230rpx;
  padding: 10rpx 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 22rpx;
  font-weight: 900;
  color: #fff0df;
  white-space: nowrap;
  background: #c2410c;
  border-radius: 6rpx;
}

.theme-layout__toolbox {
  box-sizing: border-box;
  display: flex;
  gap: 10rpx;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 64rpx;
  background: #fff0df;
  border: 3rpx solid #251812;
  border-radius: 8rpx;
}

.theme-layout__tool {
  width: 26rpx;
  height: 34rpx;
  background: #c2410c;
  border: 2rpx solid #251812;
  border-radius: 4rpx;
}

.theme-layout__tool--round {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
}

.theme-layout__tool--thin {
  width: 14rpx;
}

.theme-layout__content {
  margin-top: 20rpx;
}

.theme-layout__globals {
  display: flex;
  gap: 12rpx;
  align-items: center;
  justify-content: flex-end;
  height: 52rpx;
  margin-top: 18rpx;
  color: #251812;
}

.theme-layout__safe-area {
  padding: 8rpx 12rpx;
  font-size: 22rpx;
  font-weight: 900;
  background: #ffe1bc;
  border: 3rpx solid #251812;
  border-radius: 6rpx;
}

@keyframes theme-enter {
  from {
    opacity: 0.94;
  }

  to {
    opacity: 1;
  }
}

@keyframes theme-wipe {
  0% {
    opacity: 0;
    transform: translateX(-80%) skewX(-14deg);
  }

  18% {
    opacity: 0.95;
  }

  100% {
    opacity: 0;
    transform: translateX(230%) skewX(-14deg);
  }
}
