<view class="studio-layout" data-layout="studio">
  <view class="studio-layout__nav">
    <text class="studio-layout__brand">{{title}}</text>
    <text class="studio-layout__mode">{{mode}}</text>
  </view>
  <view class="studio-layout__stage">
    <view class="studio-layout__rail">
      <text class="studio-layout__rail-item studio-layout__rail-item--active">01</text>
      <text class="studio-layout__rail-item">02</text>
      <text class="studio-layout__rail-item">03</text>
    </view>
    <view class="studio-layout__body">
      <slot />
    </view>
  </view>
</view>
