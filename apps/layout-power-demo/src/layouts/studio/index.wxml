<view class="theme-layout theme-layout--studio" data-layout="studio">
  <view class="theme-layout__transition" />

  <view class="theme-layout__navbar" style="{{navbarStyle}}">
    <view class="theme-layout__navbar-title">
      <text class="theme-layout__swatch theme-layout__swatch--ink" />
      <text class="theme-layout__swatch theme-layout__swatch--paper" />
      <text class="theme-layout__navbar-text">布局演示</text>
    </view>
  </view>

  <view class="theme-layout__nav">
    <view class="theme-layout__brand">
      <text class="theme-layout__kicker">外壳</text>
      <text class="theme-layout__title">{{title}}</text>
    </view>
    <view class="theme-layout__toolbox">
      <text class="theme-layout__tool theme-layout__tool--round" />
      <text class="theme-layout__tool" />
      <text class="theme-layout__tool theme-layout__tool--thin" />
    </view>
  </view>

  <view class="theme-layout__content">
    <slot />
  </view>

  <view class="theme-layout__globals">
    <text class="theme-layout__mode">{{mode}}</text>
    <text class="theme-layout__safe-area">安全区</text>
  </view>

  <t-message id="t-message" />
  <t-toast id="t-toast" />
</view>
