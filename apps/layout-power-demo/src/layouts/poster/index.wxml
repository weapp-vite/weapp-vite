<view class="theme-layout theme-layout--poster" data-layout="poster">
  <view class="theme-layout__transition" />

  <view class="theme-layout__navbar">
    <view class="theme-layout__navbar-title">
      <text class="theme-layout__poster-mark">LP</text>
      <text class="theme-layout__navbar-text">Layout Power</text>
    </view>
    <text class="theme-layout__navbar-theme">POSTER</text>
  </view>

  <view class="theme-layout__nav">
    <view class="theme-layout__brand">
      <text class="theme-layout__kicker">layout host</text>
      <text class="theme-layout__title">{{title}}</text>
    </view>
    <view class="theme-layout__poster-ticket">
      <text class="theme-layout__ticket-code">A24</text>
      <text class="theme-layout__ticket-rule" />
    </view>
  </view>

  <view class="theme-layout__content">
    <slot />
  </view>

  <view class="theme-layout__globals">
    <text class="theme-layout__mode">{{mode}}</text>
    <text class="theme-layout__safe-area">safe-area</text>
  </view>
</view>
