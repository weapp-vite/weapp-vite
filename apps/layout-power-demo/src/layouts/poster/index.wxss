.theme-layout {
  position: relative;
  min-height: 100vh;
  padding: 0 28rpx 28rpx;
  overflow: hidden;
  background: #3b0764;
  animation: theme-enter 220ms ease-out both;
}

.theme-layout__transition {
  position: absolute;
  top: 0;
  bottom: 0;
  left: -42%;
  z-index: 3;
  width: 76%;
  pointer-events: none;
  background: linear-gradient(90deg, transparent, #facc15 18%, #fef3c7 72%, transparent);
  transform: skewX(-14deg);
  animation: theme-wipe 520ms cubic-bezier(0.18, 0.9, 0.22, 1) both;
}

.theme-layout__navbar {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  color: #fef3c7;
}

.theme-layout__navbar,
.theme-layout__nav,
.theme-layout__content,
.theme-layout__globals {
  position: relative;
  z-index: 1;
}

.theme-layout__navbar-text,
.theme-layout__kicker,
.theme-layout__title,
.theme-layout__mode,
.theme-layout__safe-area {
  display: block;
}

.theme-layout__navbar-title {
  display: flex;
  flex: 1;
  gap: 10rpx;
  align-items: center;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 900;
}

.theme-layout__poster-mark {
  display: block;
  width: 42rpx;
  height: 42rpx;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 42rpx;
  color: #3b0764;
  text-align: center;
  background: #facc15;
  border-radius: 50%;
}

.theme-layout__nav {
  box-sizing: border-box;
  display: flex;
  gap: 18rpx;
  align-items: center;
  justify-content: space-between;
  height: 108rpx;
  padding: 22rpx 26rpx;
  color: #3b0764;
  background: #facc15;
  border: 1rpx solid #facc15;
  border-radius: 8rpx;
  box-shadow: 0 18rpx 38rpx rgb(250 204 21 / 30%);
}

.theme-layout__brand {
  flex: 1;
  min-width: 0;
}

.theme-layout__kicker {
  font-size: 22rpx;
  font-weight: 900;
  color: rgb(59 7 100 / 70%);
  text-transform: uppercase;
}

.theme-layout__title {
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.12;
  white-space: nowrap;
}

.theme-layout__mode {
  max-width: 230rpx;
  padding: 10rpx 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 22rpx;
  font-weight: 900;
  color: #facc15;
  white-space: nowrap;
  background: #3b0764;
  border-radius: 6rpx;
}

.theme-layout__poster-ticket {
  box-sizing: border-box;
  display: flex;
  gap: 10rpx;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 64rpx;
  color: #3b0764;
  background: #fef3c7;
  border: 2rpx solid #3b0764;
  border-radius: 8rpx;
}

.theme-layout__ticket-code {
  display: block;
  font-size: 24rpx;
  font-weight: 900;
}

.theme-layout__ticket-rule {
  display: block;
  width: 2rpx;
  height: 42rpx;
  background: repeating-linear-gradient(180deg, #3b0764 0, #3b0764 6rpx, transparent 6rpx, transparent 12rpx);
}

.theme-layout__content {
  margin-top: 20rpx;
}

.theme-layout__globals {
  display: flex;
  gap: 12rpx;
  align-items: center;
  justify-content: flex-end;
  height: 52rpx;
  margin-top: 18rpx;
  color: #fef3c7;
}

.theme-layout__safe-area {
  padding: 8rpx 12rpx;
  font-size: 22rpx;
  font-weight: 900;
  color: #3b0764;
  background: #fef3c7;
  border: 1rpx solid #facc15;
  border-radius: 6rpx;
}

@keyframes theme-enter {
  from {
    opacity: 0.94;
  }

  to {
    opacity: 1;
  }
}

@keyframes theme-wipe {
  0% {
    opacity: 0;
    transform: translateX(-80%) skewX(-14deg);
  }

  18% {
    opacity: 0.95;
  }

  100% {
    opacity: 0;
    transform: translateX(230%) skewX(-14deg);
  }
}
