.theme-layout {
  min-height: 100vh;
  padding: 0 28rpx 28rpx;
  overflow: hidden;
  background: #3b0764;
  animation: theme-enter 340ms cubic-bezier(0.2, 0.8, 0.2, 1.18) both;
}

.theme-layout__navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 108rpx;
  padding-top: 48rpx;
  color: #fef3c7;
}

.theme-layout__navbar-title,
.theme-layout__navbar-theme,
.theme-layout__kicker,
.theme-layout__title,
.theme-layout__mode,
.theme-layout__toast,
.theme-layout__safe-area {
  display: block;
}

.theme-layout__navbar-title {
  font-size: 30rpx;
  font-weight: 900;
}

.theme-layout__navbar-theme {
  padding: 8rpx 12rpx;
  font-size: 20rpx;
  font-weight: 900;
  color: #3b0764;
  background: #facc15;
  border-radius: 6rpx;
}

.theme-layout__nav {
  display: flex;
  gap: 18rpx;
  align-items: center;
  justify-content: space-between;
  min-height: 108rpx;
  padding: 22rpx 26rpx;
  color: #3b0764;
  background: #facc15;
  border: 1rpx solid #facc15;
  border-radius: 8rpx;
  box-shadow: 0 18rpx 38rpx rgb(250 204 21 / 30%);
}

.theme-layout__brand {
  flex: 1;
  min-width: 0;
}

.theme-layout__kicker {
  font-size: 22rpx;
  font-weight: 900;
  color: rgb(59 7 100 / 70%);
  text-transform: uppercase;
}

.theme-layout__title {
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.12;
  white-space: nowrap;
}

.theme-layout__mode {
  max-width: 230rpx;
  padding: 10rpx 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 22rpx;
  font-weight: 900;
  color: #facc15;
  white-space: nowrap;
  background: #3b0764;
  border-radius: 6rpx;
}

.theme-layout__content {
  margin-top: 20rpx;
}

.theme-layout__globals {
  display: flex;
  gap: 12rpx;
  align-items: center;
  justify-content: flex-end;
  min-height: 52rpx;
  margin-top: 18rpx;
  color: #fef3c7;
}

.theme-layout__toast,
.theme-layout__safe-area {
  padding: 8rpx 12rpx;
  font-size: 22rpx;
  font-weight: 900;
  color: #3b0764;
  background: #fef3c7;
  border: 1rpx solid #facc15;
  border-radius: 6rpx;
}

@keyframes theme-enter {
  from {
    opacity: 0.72;
    transform: translateY(-16rpx) scale(0.975);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
