.theme-layout {
  position: relative;
  min-height: 100vh;
  padding: 0 28rpx 28rpx;
  overflow: hidden;
  background: #042f2e;
  animation: theme-enter 220ms ease-out both;
}

.theme-layout__transition {
  position: absolute;
  top: 0;
  bottom: 0;
  left: -42%;
  z-index: 3;
  width: 76%;
  pointer-events: none;
  background: linear-gradient(90deg, transparent, #2dd4bf 18%, #99f6e4 72%, transparent);
  transform: skewX(-14deg);
  animation: theme-wipe 520ms cubic-bezier(0.18, 0.9, 0.22, 1) both;
}

.theme-layout__navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 108rpx;
  padding-top: 48rpx;
  color: #ccfbf1;
}

.theme-layout__navbar,
.theme-layout__nav,
.theme-layout__content,
.theme-layout__globals {
  position: relative;
  z-index: 1;
}

.theme-layout__navbar-title,
.theme-layout__navbar-theme,
.theme-layout__kicker,
.theme-layout__title,
.theme-layout__mode,
.theme-layout__toast,
.theme-layout__safe-area {
  display: block;
}

.theme-layout__navbar-title {
  font-size: 30rpx;
  font-weight: 900;
}

.theme-layout__navbar-theme {
  padding: 8rpx 12rpx;
  font-size: 20rpx;
  font-weight: 900;
  color: #042f2e;
  background: #2dd4bf;
  border-radius: 6rpx;
}

.theme-layout__nav {
  display: flex;
  gap: 18rpx;
  align-items: center;
  justify-content: space-between;
  min-height: 108rpx;
  padding: 22rpx 26rpx;
  color: #042f2e;
  background: #99f6e4;
  border: 1rpx solid #2dd4bf;
  border-radius: 8rpx;
  box-shadow: 0 18rpx 36rpx rgb(45 212 191 / 28%);
}

.theme-layout__brand {
  flex: 1;
  min-width: 0;
}

.theme-layout__kicker {
  font-size: 22rpx;
  font-weight: 900;
  color: #0f766e;
  text-transform: uppercase;
}

.theme-layout__title {
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.12;
  white-space: nowrap;
}

.theme-layout__mode {
  max-width: 230rpx;
  padding: 10rpx 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 22rpx;
  font-weight: 900;
  color: #ccfbf1;
  white-space: nowrap;
  background: #0f766e;
  border-radius: 6rpx;
}

.theme-layout__content {
  margin-top: 20rpx;
}

.theme-layout__globals {
  display: flex;
  gap: 12rpx;
  align-items: center;
  justify-content: flex-end;
  min-height: 52rpx;
  margin-top: 18rpx;
  color: #ccfbf1;
}

.theme-layout__toast,
.theme-layout__safe-area {
  padding: 8rpx 12rpx;
  font-size: 22rpx;
  font-weight: 900;
  color: #042f2e;
  background: #99f6e4;
  border: 1rpx solid #2dd4bf;
  border-radius: 6rpx;
}

@keyframes theme-enter {
  from {
    opacity: 0.94;
  }

  to {
    opacity: 1;
  }
}

@keyframes theme-wipe {
  0% {
    opacity: 0;
    transform: translateX(-80%) skewX(-14deg);
  }

  18% {
    opacity: 0.95;
  }

  100% {
    opacity: 0;
    transform: translateX(230%) skewX(-14deg);
  }
}
