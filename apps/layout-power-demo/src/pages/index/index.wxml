<view class="{{demoClass}}">
  <view class="hero">
    <view class="hero__copy">
      <text class="hero__eyebrow">布局能力</text>
      <text class="hero__title">切换外壳，内容不动</text>
    </view>
    <view class="hero__badge">
      <text class="hero__badge-value">{{currentLayoutLabel}}</text>
      <text class="hero__badge-label">已切换 {{runtimeEvents}} 次</text>
    </view>
  </view>

  <view class="stage">
    <view class="stage__header">
      <text class="stage__label">当前外壳</text>
      <text class="stage__mode">{{layoutMode}}</text>
    </view>
    <view class="stage__body">
      <view class="stage__rail">
        <text class="stage__rail-dot stage__rail-dot--active" />
        <text class="stage__rail-dot" />
        <text class="stage__rail-dot" />
      </view>
      <view class="stage__main">
        <text class="stage__title">{{layoutTitle}}</text>
        <text class="stage__desc">页面内容保留，只替换布局、属性和骨架。</text>
        <view class="stage__facts">
          <text class="stage__fact">运行切换</text>
          <text class="stage__fact">插槽承载</text>
          <text class="stage__fact">{{currentLayoutLabel}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="switches">
    <button
      wx:for="{{layoutOptions}}"
      wx:key="value"
      class="{{item.className}}"
      data-layout="{{item.value}}"
      bindtap="switchLayout"
    >
      {{item.label}}
    </button>
  </view>
</view>
