<view class="{{demoClass}}">
  <view class="summary">
    <view class="summary__title">
      <text class="summary__eyebrow">布局能力</text>
      <text class="summary__name">切换外壳</text>
    </view>
    <view class="summary__meta">
      <text class="summary__layout">{{currentLayoutLabel}}</text>
      <text class="summary__count">{{runtimeEvents}} 次</text>
    </view>
  </view>

  <view class="stage">
    <view class="stage__header">
      <text class="stage__label">当前外壳</text>
      <text class="stage__mode">{{layoutMode}}</text>
    </view>
    <view class="stage__body">
      <view class="stage__rail">
        <text class="stage__rail-dot stage__rail-dot--active" />
        <text class="stage__rail-dot" />
        <text class="stage__rail-dot" />
      </view>
      <view class="stage__main">
        <text class="stage__title">{{layoutTitle}}</text>
        <text class="stage__desc">页面内容保留，只替换布局、属性和骨架。</text>
        <view class="stage__visual stage__visual--default">
          <text class="stage__tile stage__tile--wide" />
          <text class="stage__tile" />
          <text class="stage__tile" />
          <text class="stage__tile stage__tile--short" />
        </view>
        <view class="stage__visual stage__visual--command">
          <text class="stage__console-line stage__console-line--wide" />
          <text class="stage__console-line" />
          <text class="stage__console-cursor" />
        </view>
        <view class="stage__visual stage__visual--studio">
          <text class="stage__swatch stage__swatch--large" />
          <text class="stage__swatch stage__swatch--light" />
          <text class="stage__brush" />
        </view>
        <view class="stage__visual stage__visual--split">
          <text class="stage__pane stage__pane--main" />
          <view class="stage__pane-stack">
            <text class="stage__pane" />
            <text class="stage__pane stage__pane--thin" />
          </view>
        </view>
        <view class="stage__visual stage__visual--poster">
          <text class="stage__poster-mark">海</text>
          <view class="stage__poster-lines">
            <text class="stage__poster-line stage__poster-line--wide" />
            <text class="stage__poster-line" />
          </view>
        </view>
        <view class="stage__facts">
          <text class="stage__fact">运行切换</text>
          <text class="stage__fact">插槽承载</text>
          <text class="stage__fact">{{currentLayoutLabel}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="switches">
    <view
      wx:for="{{layoutOptions}}"
      wx:key="value"
      class="{{item.className}}"
      data-layout="{{item.value}}"
      hover-class="switch--hover"
      hover-stay-time="120"
      role="button"
      aria-label="切换到{{item.label}}布局"
      bindtap="switchLayout"
    >
      <text class="switch__label">{{item.label}}</text>
    </view>
  </view>

  <view class="feedback-actions">
    <view
      class="feedback-trigger"
      hover-class="feedback-trigger--hover"
      hover-stay-time="120"
      role="button"
      aria-label="调用当前布局 Message"
      bindtap="showLayoutMessage"
    >
      <text class="feedback-trigger__icon">M</text>
      <text class="feedback-trigger__text">Message</text>
    </view>
    <view
      class="feedback-trigger feedback-trigger--toast"
      hover-class="feedback-trigger--hover"
      hover-stay-time="120"
      role="button"
      aria-label="调用当前布局 Toast"
      bindtap="showLayoutToast"
    >
      <text class="feedback-trigger__icon">T</text>
      <text class="feedback-trigger__text">Toast</text>
    </view>
    <text class="feedback-trigger__layout">{{currentLayoutLabel}}</text>
  </view>

  <view class="showcase">
    <view class="showcase__header">
      <text class="showcase__title">布局能力</text>
      <text class="showcase__tag">{{currentLayoutLabel}}</text>
    </view>
    <view class="showcase__grid">
      <view class="showcase__item">
        <text class="showcase__item-title">插槽</text>
        <text class="showcase__item-text">内容不变</text>
      </view>
      <view class="showcase__item">
        <text class="showcase__item-title">属性</text>
        <text class="showcase__item-text">{{layoutMode}}</text>
      </view>
      <view class="showcase__item">
        <text class="showcase__item-title">次数</text>
        <text class="showcase__item-text">{{runtimeEvents}} 次</text>
      </view>
    </view>
    <view class="showcase__tracks">
      <view class="showcase__track showcase__track--wide">
        <text class="showcase__track-name">导航</text>
        <text class="showcase__track-bar" />
      </view>
      <view class="showcase__track">
        <text class="showcase__track-name">内容</text>
        <text class="showcase__track-bar" />
      </view>
      <view class="showcase__track showcase__track--short">
        <text class="showcase__track-name">挂载</text>
        <text class="showcase__track-bar" />
      </view>
    </view>
  </view>
</view>
