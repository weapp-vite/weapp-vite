<view class="{{demoClass}}">
  <view class="hero">
    <view class="hero__copy">
      <text class="hero__eyebrow">weapp-vite layout</text>
      <text class="hero__title">一屏切换不同页面外壳</text>
    </view>
    <view class="hero__badge">
      <text class="hero__badge-value">{{currentLayout}}</text>
      <text class="hero__badge-label">{{runtimeEvents}} changes</text>
    </view>
  </view>

  <view class="stage">
    <view class="stage__header">
      <text class="stage__label">current shell</text>
      <text class="stage__mode">{{layoutMode}}</text>
    </view>
    <view class="stage__body">
      <view class="stage__rail">
        <text class="stage__rail-dot stage__rail-dot--active" />
        <text class="stage__rail-dot" />
        <text class="stage__rail-dot" />
      </view>
      <view class="stage__main">
        <text class="stage__title">{{layoutTitle}}</text>
        <text class="stage__desc">同一个 page slot 不变，只替换外层 layout、props 和视觉骨架。</text>
        <view class="stage__facts">
          <text class="stage__fact">setPageLayout</text>
          <text class="stage__fact">slot</text>
          <text class="stage__fact">{{currentLayout}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="switches">
    <button
      wx:for="{{layoutOptions}}"
      wx:key="value"
      class="{{item.className}}"
      data-layout="{{item.value}}"
      bindtap="switchLayout"
    >
      {{item.label}}
    </button>
  </view>
</view>
