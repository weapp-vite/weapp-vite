.demo {
  --demo-accent: #2563eb;
  --demo-accent-2: #38bdf8;
  --demo-bg: #eef6ff;
  --demo-card: #fff;
  --demo-card-soft: #f8fafc;
  --demo-border: #d7dee8;
  --demo-ink: #101827;
  --demo-muted: #536274;
  --demo-rail: #e8eef6;
  --demo-chip-bg: #dbeafe;
  --demo-chip-ink: #12325f;
  --demo-shadow: rgb(23 32 51 / 10%);

  box-sizing: border-box;
  min-height: calc(100vh - 170rpx);
  padding: 0 0 8rpx;
  color: var(--demo-ink);
  transform-origin: 50% 48%;
}

.demo--command {
  --demo-accent: #00e5ff;
  --demo-accent-2: #ff4fd8;
  --demo-bg: #090d1f;
  --demo-card: #171b3a;
  --demo-card-soft: #10142c;
  --demo-border: #00e5ff;
  --demo-ink: #effcff;
  --demo-muted: #9cc8d6;
  --demo-rail: #0c1028;
  --demo-chip-bg: rgb(0 229 255 / 14%);
  --demo-chip-ink: #b9f7ff;
  --demo-shadow: rgb(0 229 255 / 26%);
}

.demo--studio {
  --demo-accent: #5f7c49;
  --demo-accent-2: #d6ff5f;
  --demo-bg: #fbf0dc;
  --demo-card: #fff8ec;
  --demo-card-soft: #f4e2c4;
  --demo-border: #d8b985;
  --demo-ink: #251812;
  --demo-muted: #765f4f;
  --demo-rail: #e8d1aa;
  --demo-chip-bg: #e2f7a3;
  --demo-chip-ink: #263516;
  --demo-shadow: rgb(79 54 25 / 15%);
}

.demo--split {
  --demo-accent: #0f766e;
  --demo-accent-2: #38bdf8;
  --demo-bg: #ecfeff;
  --demo-card: #f8ffff;
  --demo-card-soft: #dff8f8;
  --demo-border: #99f6e4;
  --demo-ink: #042f2e;
  --demo-muted: #426968;
  --demo-rail: #ccfbf1;
  --demo-chip-bg: #ccfbf1;
  --demo-chip-ink: #042f2e;
  --demo-shadow: rgb(15 118 110 / 16%);
}

.demo--poster {
  --demo-accent: #8b1538;
  --demo-accent-2: #facc15;
  --demo-bg: #fff5ed;
  --demo-card: #fffaf3;
  --demo-card-soft: #ffe9d0;
  --demo-border: #fecaca;
  --demo-ink: #3b0c19;
  --demo-muted: #8a4d5d;
  --demo-rail: #fee2e2;
  --demo-chip-bg: #fef3c7;
  --demo-chip-ink: #3b0c19;
  --demo-shadow: rgb(139 21 56 / 15%);
}

.demo--switching .summary,
.demo--switching .stage,
.demo--switching .switches,
.demo--switching .showcase {
  animation: switch-press 420ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.demo--settled .summary,
.demo--settled .stage,
.demo--settled .switches,
.demo--settled .showcase {
  animation: switch-settle 320ms cubic-bezier(0.18, 0.9, 0.22, 1) both;
}

.summary {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 112rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 18rpx;
  background: var(--demo-card);
  border: 1rpx solid var(--demo-border);
  border-radius: 8rpx;
  box-shadow: 0 10rpx 24rpx var(--demo-shadow);
  transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
}

.summary__title {
  flex: 1;
  min-width: 0;
}

.summary__eyebrow,
.summary__name,
.summary__layout,
.summary__count,
.stage__label,
.stage__mode,
.stage__title,
.stage__desc {
  display: block;
}

.summary__eyebrow {
  font-size: 24rpx;
  font-weight: 900;
  color: var(--demo-accent);
}

.summary__name {
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.12;
  color: var(--demo-ink);
  white-space: nowrap;
}

.summary__meta {
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 176rpx;
  height: 72rpx;
  color: var(--demo-card);
  background: var(--demo-accent);
  border-radius: 8rpx;
}

.summary__layout {
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.1;
  white-space: nowrap;
}

.summary__count {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.1;
  color: rgb(255 255 255 / 66%);
}

.stage {
  position: relative;
  overflow: hidden;
  background: var(--demo-card);
  border: 1rpx solid var(--demo-border);
  border-radius: 8rpx;
  box-shadow: 0 14rpx 32rpx var(--demo-shadow);
  transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
}

.stage__header {
  display: flex;
  gap: 16rpx;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  color: var(--demo-card);
  background: var(--demo-accent);
}

.stage__label {
  font-size: 24rpx;
  font-weight: 800;
  color: rgb(255 255 255 / 72%);
  text-transform: uppercase;
}

.stage__mode {
  max-width: 320rpx;
  padding: 8rpx 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 24rpx;
  font-weight: 900;
  color: var(--demo-ink);
  white-space: nowrap;
  background: var(--demo-accent-2);
  border-radius: 6rpx;
  transition: background-color 180ms ease, color 180ms ease;
}

.stage__body {
  display: flex;
  min-height: 334rpx;
}

.stage__rail {
  display: grid;
  gap: 14rpx;
  align-content: center;
  justify-items: center;
  width: 92rpx;
  background: var(--demo-rail);
}

.stage__rail-dot {
  width: 22rpx;
  height: 22rpx;
  background: var(--demo-muted);
  border-radius: 50%;
}

.stage__rail-dot--active {
  width: 34rpx;
  height: 34rpx;
  background: var(--demo-accent);
}

.stage__main {
  flex: 1;
  min-width: 0;
  padding: 34rpx 30rpx;
  background: linear-gradient(180deg, var(--demo-card-soft) 0%, var(--demo-bg) 100%);
  transition: background-color 180ms ease;
}

.stage__title {
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.08;
  color: var(--demo-ink);
  white-space: nowrap;
}

.stage__desc {
  margin-top: 18rpx;
  font-size: 30rpx;
  line-height: 1.38;
  color: var(--demo-muted);
}

.stage__visual {
  display: none;
  align-items: center;
  min-height: 92rpx;
  margin-top: 24rpx;
}

.demo--default .stage__visual--default,
.demo--command .stage__visual--command,
.demo--studio .stage__visual--studio,
.demo--split .stage__visual--split,
.demo--poster .stage__visual--poster {
  display: flex;
}

.stage__tile,
.stage__console-line,
.stage__console-cursor,
.stage__swatch,
.stage__brush,
.stage__pane,
.stage__poster-mark,
.stage__poster-line {
  display: block;
}

.stage__visual--default {
  display: none;
  flex-wrap: wrap;
  gap: 10rpx;
}

.stage__tile {
  width: 86rpx;
  height: 34rpx;
  background: var(--demo-chip-bg);
  border: 1rpx solid var(--demo-border);
  border-radius: 6rpx;
}

.stage__tile--wide {
  width: 132rpx;
}

.stage__tile--short {
  width: 58rpx;
}

.stage__visual--command {
  display: none;
  flex-direction: column;
  gap: 12rpx;
  align-items: flex-start;
  justify-content: center;
}

.stage__console-line {
  width: 148rpx;
  height: 14rpx;
  background: var(--demo-accent);
  border-radius: 999rpx;
  box-shadow: 0 0 16rpx var(--demo-shadow);
}

.stage__console-line--wide {
  width: 224rpx;
}

.stage__console-cursor {
  width: 22rpx;
  height: 32rpx;
  background: var(--demo-accent-2);
}

.stage__visual--studio {
  display: none;
  gap: 16rpx;
}

.stage__swatch {
  width: 58rpx;
  height: 58rpx;
  background: var(--demo-accent);
  border: 2rpx solid var(--demo-ink);
  border-radius: 6rpx;
}

.stage__swatch--large {
  width: 78rpx;
  height: 78rpx;
}

.stage__swatch--light {
  background: var(--demo-accent-2);
}

.stage__brush {
  width: 120rpx;
  height: 18rpx;
  background: var(--demo-ink);
  border-radius: 999rpx;
  transform: rotate(-8deg);
}

.stage__visual--split {
  display: none;
  gap: 14rpx;
}

.stage__pane {
  width: 96rpx;
  height: 34rpx;
  background: var(--demo-chip-bg);
  border: 1rpx solid var(--demo-accent);
  border-radius: 6rpx;
}

.stage__pane--main {
  width: 132rpx;
  height: 84rpx;
}

.stage__pane--thin {
  width: 72rpx;
}

.stage__pane-stack {
  display: grid;
  gap: 12rpx;
}

.stage__visual--poster {
  display: none;
  gap: 16rpx;
}

.stage__poster-mark {
  width: 76rpx;
  height: 76rpx;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 76rpx;
  color: var(--demo-card);
  text-align: center;
  background: var(--demo-accent);
  border-radius: 50%;
}

.stage__poster-lines {
  display: grid;
  gap: 14rpx;
}

.stage__poster-line {
  width: 120rpx;
  height: 18rpx;
  background: var(--demo-accent-2);
  border-radius: 999rpx;
}

.stage__poster-line--wide {
  width: 186rpx;
}

.stage__facts {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 28rpx;
}

.stage__fact {
  max-width: 220rpx;
  padding: 12rpx 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 24rpx;
  font-weight: 900;
  color: var(--demo-chip-ink);
  white-space: nowrap;
  background: var(--demo-chip-bg);
  border-radius: 6rpx;
  transition: background-color 180ms ease, color 180ms ease;
}

.switches {
  display: flex;
  gap: 8rpx;
  margin-top: 18rpx;
}

.switch {
  box-sizing: border-box;
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 56rpx;
  padding: 0 4rpx;
  overflow: hidden;
  color: var(--demo-ink);
  text-align: center;
  background: var(--demo-card-soft);
  border-radius: 8rpx;
  transition: background-color 180ms ease, color 180ms ease, border-color 180ms ease, transform 180ms ease;
}

.switch__label {
  display: block;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.1;
  white-space: nowrap;
}

.switch--hover {
  transform: translateY(2rpx);
}

.switch--active {
  color: var(--demo-card);
  background: var(--demo-accent);
  border: 1rpx solid var(--demo-accent);
  box-shadow: 0 10rpx 24rpx var(--demo-shadow);
}

.showcase {
  box-sizing: border-box;
  min-height: 308rpx;
  padding: 22rpx 24rpx;
  margin-top: 18rpx;
  background: var(--demo-card);
  border: 1rpx solid var(--demo-border);
  border-radius: 8rpx;
  box-shadow: 0 14rpx 32rpx var(--demo-shadow);
  transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
}

.showcase__header {
  display: flex;
  gap: 18rpx;
  align-items: center;
  justify-content: space-between;
}

.showcase__title,
.showcase__tag,
.showcase__item-title,
.showcase__item-text,
.showcase__track-name,
.showcase__track-bar {
  display: block;
}

.showcase__title {
  font-size: 30rpx;
  font-weight: 900;
  color: var(--demo-ink);
}

.showcase__tag {
  max-width: 180rpx;
  padding: 8rpx 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 22rpx;
  font-weight: 900;
  color: var(--demo-card);
  white-space: nowrap;
  background: var(--demo-accent);
  border-radius: 6rpx;
}

.showcase__grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.showcase__item {
  box-sizing: border-box;
  min-height: 104rpx;
  padding: 16rpx 14rpx;
  background: var(--demo-card-soft);
  border: 1rpx solid var(--demo-border);
  border-radius: 8rpx;
}

.showcase__item-title {
  font-size: 22rpx;
  font-weight: 900;
  color: var(--demo-muted);
}

.showcase__item-text {
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 26rpx;
  font-weight: 900;
  color: var(--demo-ink);
  white-space: nowrap;
}

.showcase__tracks {
  display: grid;
  gap: 12rpx;
  margin-top: 20rpx;
}

.showcase__track {
  display: grid;
  grid-template-columns: 76rpx minmax(0, 1fr);
  gap: 16rpx;
  align-items: center;
}

.showcase__track-name {
  font-size: 22rpx;
  font-weight: 900;
  color: var(--demo-muted);
}

.showcase__track-bar {
  width: 76%;
  height: 18rpx;
  background: linear-gradient(90deg, var(--demo-accent) 0%, var(--demo-accent-2) 100%);
  border-radius: 999rpx;
}

.showcase__track--wide .showcase__track-bar {
  width: 100%;
}

.showcase__track--short .showcase__track-bar {
  width: 56%;
}

@keyframes switch-press {
  0% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  42% {
    opacity: 0.72;
    transform: translateY(10rpx) scale(0.975);
  }

  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes switch-settle {
  0% {
    opacity: 0.92;
    transform: translateY(-8rpx) scale(1.012);
  }

  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
