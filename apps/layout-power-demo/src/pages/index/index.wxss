.demo {
  box-sizing: border-box;
  min-height: calc(100vh - 170rpx);
  padding: 0 0 8rpx;
  color: #172033;
  transform-origin: 50% 48%;
}

.demo--switching .summary,
.demo--switching .stage,
.demo--switching .switches,
.demo--switching .showcase {
  animation: switch-press 420ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.demo--settled .summary,
.demo--settled .stage,
.demo--settled .switches,
.demo--settled .showcase {
  animation: switch-settle 320ms cubic-bezier(0.18, 0.9, 0.22, 1) both;
}

.summary {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 112rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 18rpx;
  background: #fff;
  border: 1rpx solid #d7dee8;
  border-radius: 8rpx;
  box-shadow: 0 10rpx 24rpx rgb(23 32 51 / 9%);
}

.summary__title {
  flex: 1;
  min-width: 0;
}

.summary__eyebrow,
.summary__name,
.summary__layout,
.summary__count,
.stage__label,
.stage__mode,
.stage__title,
.stage__desc {
  display: block;
}

.summary__eyebrow {
  font-size: 24rpx;
  font-weight: 900;
  color: #2563eb;
}

.summary__name {
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.12;
  color: #101827;
  white-space: nowrap;
}

.summary__meta {
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 176rpx;
  height: 72rpx;
  color: #fff;
  background: #172033;
  border-radius: 8rpx;
}

.summary__layout {
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.1;
  white-space: nowrap;
}

.summary__count {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.1;
  color: rgb(255 255 255 / 66%);
}

.stage {
  position: relative;
  overflow: hidden;
  background: #fff;
  border: 1rpx solid #d7dee8;
  border-radius: 8rpx;
  box-shadow: 0 14rpx 32rpx rgb(23 32 51 / 10%);
  transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
}

.stage__header {
  display: flex;
  gap: 16rpx;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  color: #fff;
  background: #101827;
}

.stage__label {
  font-size: 24rpx;
  font-weight: 800;
  color: rgb(255 255 255 / 64%);
  text-transform: uppercase;
}

.stage__mode {
  max-width: 320rpx;
  padding: 8rpx 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 24rpx;
  font-weight: 900;
  color: #101827;
  white-space: nowrap;
  background: #facc15;
  border-radius: 6rpx;
  transition: background-color 180ms ease, color 180ms ease;
}

.stage__body {
  display: flex;
  min-height: 334rpx;
}

.stage__rail {
  display: grid;
  gap: 14rpx;
  align-content: center;
  justify-items: center;
  width: 92rpx;
  background: #e8eef6;
}

.stage__rail-dot {
  width: 22rpx;
  height: 22rpx;
  background: #94a3b8;
  border-radius: 50%;
}

.stage__rail-dot--active {
  width: 34rpx;
  height: 34rpx;
  background: #2563eb;
}

.stage__main {
  flex: 1;
  min-width: 0;
  padding: 34rpx 30rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #eef4fb 100%);
  transition: background-color 180ms ease;
}

.stage__title {
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.08;
  color: #101827;
  white-space: nowrap;
}

.stage__desc {
  margin-top: 18rpx;
  font-size: 30rpx;
  line-height: 1.38;
  color: #536274;
}

.stage__facts {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 28rpx;
}

.stage__fact {
  max-width: 220rpx;
  padding: 12rpx 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 24rpx;
  font-weight: 900;
  color: #0f3d34;
  white-space: nowrap;
  background: #d1fae5;
  border-radius: 6rpx;
  transition: background-color 180ms ease, color 180ms ease;
}

.switches {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.switch {
  box-sizing: border-box;
  height: 64rpx;
  padding: 0 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 64rpx;
  color: #172033;
  text-align: center;
  white-space: nowrap;
  background: #eef2f7;
  border-radius: 8rpx;
  transition: background-color 180ms ease, color 180ms ease, border-color 180ms ease;
}

.switch--active {
  color: #fff;
  background: #2563eb;
  border: 1rpx solid #2563eb;
  box-shadow: 0 10rpx 24rpx rgb(37 99 235 / 28%);
}

.showcase {
  box-sizing: border-box;
  min-height: 308rpx;
  padding: 22rpx 24rpx;
  margin-top: 18rpx;
  background: #fff;
  border: 1rpx solid #d7dee8;
  border-radius: 8rpx;
  box-shadow: 0 14rpx 32rpx rgb(23 32 51 / 10%);
}

.showcase__header {
  display: flex;
  gap: 18rpx;
  align-items: center;
  justify-content: space-between;
}

.showcase__title,
.showcase__tag,
.showcase__item-title,
.showcase__item-text,
.showcase__track-name,
.showcase__track-bar {
  display: block;
}

.showcase__title {
  font-size: 30rpx;
  font-weight: 900;
  color: #101827;
}

.showcase__tag {
  max-width: 180rpx;
  padding: 8rpx 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 22rpx;
  font-weight: 900;
  color: #fff;
  white-space: nowrap;
  background: #172033;
  border-radius: 6rpx;
}

.showcase__grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.showcase__item {
  box-sizing: border-box;
  min-height: 104rpx;
  padding: 16rpx 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
}

.showcase__item-title {
  font-size: 22rpx;
  font-weight: 900;
  color: #64748b;
}

.showcase__item-text {
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 26rpx;
  font-weight: 900;
  color: #101827;
  white-space: nowrap;
}

.showcase__tracks {
  display: grid;
  gap: 12rpx;
  margin-top: 20rpx;
}

.showcase__track {
  display: grid;
  grid-template-columns: 76rpx minmax(0, 1fr);
  gap: 16rpx;
  align-items: center;
}

.showcase__track-name {
  font-size: 22rpx;
  font-weight: 900;
  color: #536274;
}

.showcase__track-bar {
  height: 18rpx;
  background: linear-gradient(90deg, #2563eb 0%, #38bdf8 100%);
  border-radius: 999rpx;
}

.showcase__track--wide .showcase__track-bar {
  width: 100%;
}

.showcase__track:not(.showcase__track--wide, .showcase__track--short) .showcase__track-bar {
  width: 76%;
}

.showcase__track--short .showcase__track-bar {
  width: 56%;
}

@keyframes switch-press {
  0% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  42% {
    opacity: 0.72;
    transform: translateY(10rpx) scale(0.975);
  }

  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes switch-settle {
  0% {
    opacity: 0.92;
    transform: translateY(-8rpx) scale(1.012);
  }

  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
