.demo {
  box-sizing: border-box;
  min-height: calc(100vh - 170rpx);
  padding: 0 0 8rpx;
  color: #172033;
}

.hero {
  display: flex;
  gap: 18rpx;
  align-items: stretch;
  margin-bottom: 18rpx;
}

.hero__copy {
  flex: 1;
  min-width: 0;
  padding: 24rpx;
  background: #fff;
  border: 1rpx solid #d7dee8;
  border-radius: 8rpx;
  box-shadow: 0 10rpx 24rpx rgb(23 32 51 / 9%);
  transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
}

.hero__eyebrow,
.hero__title,
.hero__badge-value,
.hero__badge-label,
.stage__label,
.stage__mode,
.stage__title,
.stage__desc {
  display: block;
}

.hero__eyebrow {
  font-size: 24rpx;
  font-weight: 900;
  color: #2563eb;
  text-transform: uppercase;
}

.hero__title {
  margin-top: 8rpx;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.12;
  color: #101827;
}

.hero__badge {
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: 210rpx;
  padding: 22rpx;
  color: #fff;
  background: #172033;
  border-radius: 8rpx;
  transition: background-color 180ms ease, transform 180ms ease;
}

.hero__badge-value {
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 36rpx;
  font-weight: 900;
  white-space: nowrap;
}

.hero__badge-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgb(255 255 255 / 66%);
}

.stage {
  position: relative;
  overflow: hidden;
  background: #fff;
  border: 1rpx solid #d7dee8;
  border-radius: 8rpx;
  box-shadow: 0 14rpx 32rpx rgb(23 32 51 / 10%);
  transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
}

.stage::after {
  position: absolute;
  top: 0;
  left: -70%;
  width: 50%;
  height: 100%;
  pointer-events: none;
  content: "";
  background: linear-gradient(90deg, transparent, rgb(255 255 255 / 42%), transparent);
  animation: stage-sweep 560ms ease-out both;
}

.stage__header {
  display: flex;
  gap: 16rpx;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  color: #fff;
  background: #101827;
}

.stage__label {
  font-size: 24rpx;
  font-weight: 800;
  color: rgb(255 255 255 / 64%);
  text-transform: uppercase;
}

.stage__mode {
  max-width: 320rpx;
  padding: 8rpx 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 24rpx;
  font-weight: 900;
  color: #101827;
  white-space: nowrap;
  background: #facc15;
  border-radius: 6rpx;
  transition: background-color 180ms ease, color 180ms ease;
}

.stage__body {
  display: flex;
  min-height: 334rpx;
}

.stage__rail {
  display: grid;
  gap: 14rpx;
  align-content: center;
  justify-items: center;
  width: 92rpx;
  background: #e8eef6;
}

.stage__rail-dot {
  width: 22rpx;
  height: 22rpx;
  background: #94a3b8;
  border-radius: 50%;
}

.stage__rail-dot--active {
  width: 34rpx;
  height: 34rpx;
  background: #2563eb;
}

.stage__main {
  flex: 1;
  min-width: 0;
  padding: 34rpx 30rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #eef4fb 100%);
  transition: background-color 180ms ease;
}

.stage__title {
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.08;
  color: #101827;
  white-space: nowrap;
}

.stage__desc {
  margin-top: 18rpx;
  font-size: 30rpx;
  line-height: 1.38;
  color: #536274;
}

.stage__facts {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 28rpx;
}

.stage__fact {
  max-width: 220rpx;
  padding: 12rpx 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 24rpx;
  font-weight: 900;
  color: #0f3d34;
  white-space: nowrap;
  background: #d1fae5;
  border-radius: 6rpx;
  transition: background-color 180ms ease, color 180ms ease;
}

.switches {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.switch {
  min-height: 82rpx;
  padding: 0 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 82rpx;
  color: #172033;
  white-space: nowrap;
  background: #eef2f7;
  border-radius: 8rpx;
  transition: background-color 180ms ease, color 180ms ease, transform 180ms ease;
}

.switch--active {
  color: #fff;
  background: #2563eb;
  box-shadow: 0 10rpx 24rpx rgb(37 99 235 / 28%);
  transform: translateY(-4rpx) scale(1.02);
}

@keyframes stage-sweep {
  from {
    left: -70%;
  }

  to {
    left: 120%;
  }
}
