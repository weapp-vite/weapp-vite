{
  "name": "runtime-bench-vue",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "description": "wevu Vue SFC 运行时 benchmark 基准工程",
  "scripts": {
    "dev": "wv dev",
    "dev:open": "wv dev -o",
    "build": "wv build",
    "typecheck": "vue-tsc --noEmit -p .weapp-vite/tsconfig.app.json",
    "open": "wv open",
    "postinstall": "wv prepare",
    "dev:ui": "wv dev --ui",
    "build:ui": "wv build --ui"
  },
  "devDependencies": {
    "@weapp-vite/dashboard": "workspace:*",
    "miniprogram-api-typings": "catalog:",
    "typescript": "catalog:",
    "vue-tsc": "catalog:",
    "weapp-vite": "workspace:*",
    "wevu": "workspace:*"
  }
}
