{
  "name": "runtime-bench-vue",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "description": "wevu Vue SFC 运行时 benchmark 基准工程",
  "scripts": {
    "dev": "weapp-vite dev",
    "dev:open": "weapp-vite dev -o",
    "build": "weapp-vite build",
    "typecheck": "vue-tsc --noEmit -p .weapp-vite/tsconfig.app.json",
    "open": "weapp-vite open",
    "postinstall": "weapp-vite prepare",
    "dev:ui": "weapp-vite dev --ui",
    "build:ui": "weapp-vite build --ui"
  },
  "devDependencies": {
    "@weapp-vite/dashboard": "workspace:*",
    "miniprogram-api-typings": "catalog:",
    "typescript": "catalog:",
    "vue-tsc": "catalog:",
    "weapp-vite": "workspace:*",
    "wevu": "workspace:*"
  }
}
