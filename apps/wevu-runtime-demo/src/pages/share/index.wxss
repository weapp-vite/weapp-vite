.page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx;
}

.card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 32rpx rgb(15 23 42 / 8%);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.field-label {
  font-size: 26rpx;
  color: #4b5563;
}

.field-input {
  padding: 14rpx 16rpx;
  margin-top: 4rpx;
  font-size: 28rpx;
  background: #f4f4f5;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
}

.meta {
  font-size: 26rpx;
  color: #6b7280;
}
