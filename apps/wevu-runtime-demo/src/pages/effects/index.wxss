.page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx;
}

.card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 32rpx rgb(15 23 42 / 8%);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.input {
  box-sizing: border-box;
  flex: 1;
  padding: 18rpx 22rpx;
  background: #f4f4f5;
  border-radius: 16rpx;
}

.log-item {
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #1f2937;
  background: #f4f4f5;
  border-radius: 12rpx;
}

.empty {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
}

