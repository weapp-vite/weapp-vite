.page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx;
}

.card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 32rpx rgb(15 23 42 / 8%);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.meta {
  font-size: 26rpx;
  color: #6b7280;
}

