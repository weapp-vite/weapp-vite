.filter-wrap {
  position: relative;
  display: flex;
  justify-content: space-between;
  width: 100%;
  height: 88rpx;
  background: #fff;
}

.filter-right-content {
  flex-basis: 100rpx;
  height: 100%;
  line-height: 88rpx;
  text-align: center;
}

.filter-left-content {
  display: flex;
  flex-grow: 2;
  flex-flow: row nowrap;
  justify-content: space-between;
  height: 100%;
}

.filter-left-content .filter-item {
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: center;
  height: 100%;
  font-size: 26rpx;
  font-weight: 400;
  line-height: 36rpx;
  color: rgb(51 51 51 / 100%);
}

.filter-left-content .filter-item .filter-price {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  margin-left: 6rpx;
}

.filter-left-content .filter-item .wr-filter {
  margin-left: 8rpx;
}

.filter-left-content .filter-active-item {
  color: #fa550f;
}
