.loading-content {
  position: relative;
  width: 100%;
  height: 100%;
  background-color: rgb(0 0 0 / 60%);
}

.loading-content.absolute {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.loading-content.fixed {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 1;
}

.loading-content .loading {
  visibility: visible;
  width: 100%;
  height: 100%;
}
