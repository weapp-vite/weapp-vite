.footer-cont {
  padding: 16rpx;
  background-color: #fff;
}

.icon-warp {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 110rpx;
  text-align: center;
}

.operate-wrap {
  position: relative;
}

.bottom-operate-left {
  width: 100%;
}

.bottom-operate-left .icon-warp {
  width: 50%;
}

.tag-cart-num {
  position: absolute;
  top: 6rpx;
  right: auto;
  left: 50rpx;
  z-index: 99;
  display: inline-block;
  min-width: 28rpx;
  padding: 2rpx 6rpx;
  font-size: 20rpx;
  font-weight: 400;
  line-height: 24rpx;
  color: #fff;
  text-align: center;
  white-space: nowrap;
  background-color: #fa550f !important;
  border-radius: 14rpx;
}

.operate-text {
  font-size: 20rpx;
  color: #666;
}

.soldout {
  width: 100%;
  height: 80rpx;
  color: #fff;
  background: rgb(170 170 170 / 100%);
}

.addCart-disabled,
.bar-addCart-disabled {
  font-size: 28rpx;
  color: #fff !important;
  background: rgb(221 221 221 / 100%) !important;
}

.buyNow-disabled,
.bar-buyNow-disabled {
  font-size: 28rpx;
  color: #fff !important;
  background: rgb(198 198 198 / 100%) !important;
}

.bar-separately,
.bar-buy {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 254rpx;
  height: 80rpx;
  color: #fff;
}

.bar-separately {
  color: #fa4126;
  background: #ffece9;
  border-radius: 40rpx 0 0 40rpx;
}

.bar-buy {
  background-color: #fa4126;
  border-radius: 0rpx 40rpx 40rpx 0rpx;
}

.flex {
  display: flex;
  display: flex;
}

.flex-center {
  align-items: center;
  align-items: center;
  justify-content: center;
  justify-content: center;
}

.flex-between {
  justify-content: space-between;
  justify-content: space-between;
}
