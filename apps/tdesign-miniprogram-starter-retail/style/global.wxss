.border-around,
.border-bottom-1px,
.border-left-1px,
.border-right-1px,
.border-top-1px {
  position: relative;
  border: 1rpx solid #e9e9e9;
}

.border-top-1px {
  border-width: 1rpx 0 0;
}

.border-right-1px {
  border-width: 0 1rpx 0 0;
}

.border-bottom-1px {
  border-width: 0 0 1rpx;
}

.border-left-1px {
  border-width: 0 0 0 1rpx;
}

.border-t-1px,
.border-r-1px,
.border-b-1px,
.border-l-1px {
  position: relative;
}

.border-t-1px::after,
.border-r-1px::after,
.border-b-1px::after,
.border-l-1px::after {
  position: absolute;
  content: '';
  border-color: #efefef;
  border-style: solid;
  border-width: 2rpx;
}

.border-t-1px::after {
  top: 0;
  left: 0;
  width: 100%;
  transform: scaleY(0.5);
}

.border-b-1px::after {
  bottom: 0;
  left: 0;
  width: 100%;
  transform: scaleY(0.5);
}

.border-l-1px::after {
  top: 0;
  left: 0;
  height: 100%;
  transform: scaleX(0.5);
}

.border-r-1px::after {
  top: 0;
  right: 0;
  height: 100%;
  transform: scaleX(0.5);
}

.arrows {
