  margin-top: -3px;
  content: '';
  border: 2px solid #c3c3c3;
  border-width: 2px 2px 0 0;
  transform: rotate(45deg);
  transform: rotate(45deg);
}

.arrows-inline::after {
  position: relative;
  inset: auto;
  margin-top: -4px;
  margin-left: 5px;
}

