<view class="page">
  <view class="topbar">
    <view class="title-block">
      <view class="eyebrow">weapp.forwardConsole</view>
      <view class="title">{{title}}</view>
      <view class="description">{{description}}</view>
    </view>
    <view class="status-pill">
      <view class="status-dot dot-{{activeLevel}}"></view>
      <text>{{eventCount}} events</text>
    </view>
  </view>

  <view class="terminal">
    <view class="terminal-top">
      <view class="terminal-title">Forwarded output</view>
      <view class="terminal-level">{{activeLevel}}</view>
    </view>
    <view class="terminal-line">{{lastTerminalLine}}</view>
  </view>

  <view class="action-grid">
    <button
      wx:for="{{actions}}"
      wx:key="key"
      class="action-button action-{{item.level}}"
      data-level="{{item.level}}"
      bind:tap="onEmitLog"
    >
      <view class="action-title">{{item.title}}</view>
      <view class="action-desc">{{item.description}}</view>
    </button>
  </view>

  <view class="tool-row">
    <button class="wide-button" bind:tap="onEmitBatch">
      <view class="wide-title">连续输出</view>
      <view class="wide-desc">log / info / warn</view>
    </button>
    <button class="wide-button danger" bind:tap="onEmitErrorLog">
      <view class="wide-title">错误日志</view>
      <view class="wide-desc">console.error</view>
    </button>
  </view>

  <view class="timeline-panel">
    <view class="section-title">最近事件</view>
    <view wx:for="{{timeline}}" wx:key="id" class="timeline-item">
      <view class="timeline-dot dot-{{item.level}}"></view>
      <view class="timeline-body">
        <view class="timeline-row">
          <view class="timeline-label">{{item.label}}</view>
          <view class="timeline-time">{{item.time}}</view>
        </view>
        <view class="timeline-terminal">{{item.terminal}}</view>
      </view>
    </view>
  </view>
</view>
