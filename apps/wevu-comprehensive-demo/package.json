{
  "name": "wevu-comprehensive-demo",
  "version": "0.0.102",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "description": "WeVu comprehensive demo showcasing all features",
  "scripts": {
    "prepare:weapp": "wv prepare",
    "dev": "wv dev",
    "dev:open": "wv dev -o",
    "build": "wv build",
    "typecheck": "vue-tsc --noEmit -p .weapp-vite/tsconfig.app.json",
    "open": "wv open",
    "postinstall": "wv prepare",
    "dev:ui": "wv dev --ui",
    "build:ui": "wv build --ui"
  },
  "dependencies": {
    "@vant/weapp": "catalog:",
    "tdesign-miniprogram": "catalog:",
    "wevu": "workspace:*"
  },
  "devDependencies": {
    "@weapp-core/schematics": "workspace:*",
    "@weapp-vite/dashboard": "workspace:*",
    "@weapp-vite/volar": "workspace:*",
    "miniprogram-api-typings": "catalog:latest",
    "typescript": "catalog:latest",
    "weapp-vite": "workspace:*"
  }
}
