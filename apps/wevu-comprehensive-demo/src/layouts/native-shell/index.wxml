<view class="native-shell">
  <view class="native-shell__hero">
    <text class="native-shell__eyebrow">layouts/native-shell/index.wxml</text>
    <text class="native-shell__title">{{title}}</text>
    <text class="native-shell__subtitle">页面内容通过原生组件的 slot 投递到这个布局里。</text>
  </view>
  <view wx:if="{{sidebar}}" class="native-shell__toolbar">
    <text class="native-shell__toolbar-badge">sidebar=true</text>
    <text class="native-shell__toolbar-text">这个标记来自 definePageMeta().layout.props</text>
  </view>
  <view class="native-shell__body">
    <slot />
  </view>
</view>
