.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: #ededed;
}

.message-list {
  box-sizing: border-box;
  flex: 1;
  min-height: 0;
  padding: 28rpx 24rpx 36rpx;
}

.message {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.message--mine {
  flex-direction: row-reverse;
}

.message--system {
  justify-content: center;
}

.message__avatar {
  position: relative;
  display: flex;
  flex: 0 0 72rpx;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  overflow: hidden;
  border-radius: 10rpx;
  box-shadow: 0 1rpx 3rpx rgb(0 0 0 / 8%);
}

.message__avatar--yang {
  background:
    radial-gradient(circle at 60rpx 14rpx, rgb(255 255 255 / 42%) 0 10rpx, transparent 11rpx),
    linear-gradient(135deg, #b7c9dd 0%, #e8f0f6 100%);
}

.message__avatar--me {
  background:
    radial-gradient(circle at 58rpx 14rpx, rgb(255 255 255 / 45%) 0 9rpx, transparent 10rpx),
    linear-gradient(135deg, #78b88a 0%, #d9ecd6 100%);
}

.message__avatar-hair {
  position: absolute;
  top: 10rpx;
  left: 17rpx;
  z-index: 1;
  width: 38rpx;
  height: 24rpx;
  background: #4d4036;
  border-radius: 26rpx 26rpx 12rpx 12rpx;
}

.message__avatar--me .message__avatar-hair {
  background: #263238;
}

.message__avatar-head {
  position: absolute;
  top: 17rpx;
  left: 21rpx;
  z-index: 2;
  width: 30rpx;
  height: 30rpx;
  background: #f0c7a0;
  border-radius: 50%;
}

.message__avatar--yang .message__avatar-head {
  background: #d9ad87;
}

.message__avatar-body {
  position: absolute;
  right: 13rpx;
  bottom: 7rpx;
  left: 13rpx;
  height: 28rpx;
  background:
    linear-gradient(90deg, transparent 0 15rpx, rgb(255 255 255 / 35%) 16rpx 20rpx, transparent 21rpx),
    #355c7d;
  border-radius: 28rpx 28rpx 8rpx 8rpx;
}

.message__avatar--me .message__avatar-body {
  background:
    linear-gradient(90deg, transparent 0 15rpx, rgb(255 255 255 / 32%) 16rpx 20rpx, transparent 21rpx),
    #168047;
}

.message__body {
  max-width: 560rpx;
}

.message--mine .message__body {
  align-items: flex-end;
}

.message__bubble {
  position: relative;
  padding: 18rpx 22rpx;
  font-size: 30rpx;
  line-height: 1.45;
  overflow-wrap: anywhere;
  background: #fff;
  border-radius: 8rpx;
}

.message--mine .message__bubble {
  background: #95ec69;
}

.message--system .message__bubble {
  max-width: 560rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
  background: rgb(0 0 0 / 8%);
  border-radius: 999rpx;
}

.composer {
  display: flex;
  gap: 16rpx;
  align-items: center;
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #f7f7f7;
  border-top: 1rpx solid rgb(0 0 0 / 8%);
}

.composer__input {
  box-sizing: border-box;
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  background: #fff;
  border-radius: 8rpx;
}

.composer__button {
  width: 132rpx;
  height: 76rpx;
  padding: 0;
  margin: 0;
  font-size: 28rpx;
  line-height: 76rpx;
  color: #fff;
  background: #07c160;
  border-radius: 8rpx;
}

.composer__button::after {
  border: 0;
}
