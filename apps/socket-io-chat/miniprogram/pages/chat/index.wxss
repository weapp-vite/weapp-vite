.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: #ededed;
}

.message-list {
  box-sizing: border-box;
  flex: 1;
  min-height: 0;
  height: 0;
  background: #ededed;
}

.message-list__content {
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  min-height: 100%;
  padding: 28rpx 24rpx 38rpx;
}

.message {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.message:last-child {
  margin-bottom: 0;
}

.message--mine {
  flex-direction: row-reverse;
}

.message--system {
  justify-content: center;
}

.message__avatar {
  position: relative;
  display: flex;
  flex: 0 0 76rpx;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  overflow: hidden;
  border-radius: 8rpx;
  box-shadow: 0 1rpx 3rpx rgb(0 0 0 / 8%);
}

.message__avatar--yang {
  background:
    radial-gradient(circle at 60rpx 14rpx, rgb(255 255 255 / 42%) 0 10rpx, transparent 11rpx),
    linear-gradient(135deg, #b7c9dd 0%, #e8f0f6 100%);
}

.message__avatar--me {
  background:
    radial-gradient(circle at 58rpx 14rpx, rgb(255 255 255 / 45%) 0 9rpx, transparent 10rpx),
    linear-gradient(135deg, #78b88a 0%, #d9ecd6 100%);
}

.message__avatar-hair {
  position: absolute;
  top: 11rpx;
  left: 19rpx;
  z-index: 1;
  width: 38rpx;
  height: 24rpx;
  background: #4d4036;
  border-radius: 26rpx 26rpx 12rpx 12rpx;
}

.message__avatar--me .message__avatar-hair {
  background: #263238;
}

.message__avatar-head {
  position: absolute;
  top: 18rpx;
  left: 23rpx;
  z-index: 2;
  width: 30rpx;
  height: 30rpx;
  background: #f0c7a0;
  border-radius: 50%;
}

.message__avatar--yang .message__avatar-head {
  background: #d9ad87;
}

.message__avatar-body {
  position: absolute;
  right: 14rpx;
  bottom: 8rpx;
  left: 14rpx;
  height: 28rpx;
  background:
    linear-gradient(90deg, transparent 0 15rpx, rgb(255 255 255 / 35%) 16rpx 20rpx, transparent 21rpx),
    #355c7d;
  border-radius: 28rpx 28rpx 8rpx 8rpx;
}

.message__avatar--me .message__avatar-body {
  background:
    linear-gradient(90deg, transparent 0 15rpx, rgb(255 255 255 / 32%) 16rpx 20rpx, transparent 21rpx),
    #168047;
}

.message__body {
  display: flex;
  max-width: 538rpx;
}

.message--mine .message__body {
  justify-content: flex-end;
}

.message__bubble {
  position: relative;
  box-sizing: border-box;
  min-height: 72rpx;
  padding: 18rpx 22rpx;
  font-size: 30rpx;
  line-height: 1.42;
  color: #111;
  overflow-wrap: anywhere;
  word-break: break-word;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.message__bubble::before {
  position: absolute;
  top: 22rpx;
  left: -10rpx;
  width: 0;
  height: 0;
  content: "";
  border-top: 9rpx solid transparent;
  border-right: 11rpx solid #f5f5f5;
  border-bottom: 9rpx solid transparent;
}

.message--mine .message__bubble {
  background: #95ec69;
}

.message--mine .message__bubble::before {
  right: -10rpx;
  left: auto;
  border-right: 0;
  border-left: 11rpx solid #95ec69;
}

.message--system .message__bubble {
  max-width: 560rpx;
  min-height: 0;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  line-height: 1.35;
  color: #666;
  text-align: center;
  background: rgb(0 0 0 / 8%);
  border-radius: 999rpx;
}

.message--system .message__bubble::before {
  display: none;
}

.composer {
  display: flex;
  gap: 16rpx;
  align-items: center;
  padding: 14rpx 20rpx calc(14rpx + env(safe-area-inset-bottom));
  background: #f7f7f7;
  border-top: 1rpx solid rgb(0 0 0 / 8%);
}

.composer__input {
  box-sizing: border-box;
  flex: 1;
  min-width: 0;
  height: 68rpx;
  padding: 0 22rpx;
  font-size: 28rpx;
  background: #fff;
  border-radius: 8rpx;
}

.composer__button {
  flex: 0 0 104rpx;
  width: 104rpx;
  height: 64rpx;
  padding: 0;
  margin: 0;
  font-size: 24rpx;
  line-height: 64rpx;
  color: #fff;
  background: #07c160;
  border-radius: 8rpx;
}

.composer__button::after {
  border: 0;
}
