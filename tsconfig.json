{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": [
        "./packages/weapp-vite/src/*"
      ]
    },
    "resolveJsonModule": true,
    "types": [
      "node",
      "vitest/globals",
      "vue/jsx"
    ],
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "vueCompilerOptions": {
    "plugins": [
      "@weapp-vite/volar"
    ],
    "lib": "wevu"
  },
  "include": [
    "*.ts",
    "*.mts",
    "*.cts",
    "*.d.ts",
    "apps",
    "packages",
    "templates",
    "@weapp-core",
    "website",
    "scripts",
    "e2e",
    "docs",
    "assets"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "dist",
    "dist-*",
    "dist-plugin",
    "dist-web",
    "coverage",
    "**/dist",
    "**/dist/**",
    "**/dist-*",
    "**/dist-*/**",
    "**/dist-plugin",
    "**/dist-plugin/**",
    "**/dist-web",
    "**/dist-web/**",
    "**/build",
    "**/build/**",
    "**/miniprogram_dist",
    "**/miniprogram_dist/**",
    "**/miniprogram_npm",
    "**/miniprogram_npm/**",
    "**/.vite",
    "**/.vite/**",
    "**/.vite-inspect",
    "**/.vite-inspect/**",
    "**/.turbo",
    "**/.turbo/**",
    "**/.cache",
    "**/.cache/**",
    "**/coverage",
    "**/coverage/**",
    "**/__temp__",
    "**/__temp__/**",
    "**/.tmp",
    "**/.tmp/**",
    "**/.weapp-vite",
    "**/.weapp-vite/**",
    "**/.wevu-config",
    "**/.wevu-config/**",
    "docs/reports",
    "docs/reports/**"
  ]
}
