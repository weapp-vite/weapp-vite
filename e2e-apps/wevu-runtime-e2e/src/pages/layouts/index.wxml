<view class="page">
  <view class="hero">
    <view class="hero__eyebrow">LAYOUTS-PAGE-TEMPLATE-BASE</view>
    <view class="hero__title">Layouts HMR Playground</view>
    <view class="hero__desc">current: {{currentLayout}}</view>
    <view class="hero__desc">script: {{scriptMarker}}</view>
  </view>

  <view wx:for="{{cards}}" wx:key="title" class="card">
    <view class="card__title">{{item.title}}</view>
    <view class="card__desc">{{item.desc}}</view>
  </view>

  <view class="actions">
    <button class="action-btn" bindtap="applyDefaultLayout">default</button>
    <button class="action-btn action-btn--primary" bindtap="applyAdminLayout">admin</button>
    <button class="action-btn action-btn--ghost" bindtap="clearLayout">none</button>
  </view>
</view>
