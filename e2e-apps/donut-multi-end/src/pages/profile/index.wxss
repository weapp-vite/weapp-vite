.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx;
  color: #1f2937;
  background: #fff;
}

.header,
.panel {
  padding: 24rpx;
  background: #fff;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
}

.header {
  background: #f8fafc;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #475569;
}

.tags,
.actions {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.tags {
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.panel,
.actions {
  margin-top: 20rpx;
}

.actions t-button {
  flex: 1;
}
