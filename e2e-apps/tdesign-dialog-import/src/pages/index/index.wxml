<view class="page">
  <view class="hero">
    <text class="title">tdesign Dialog dedicated app</text>
    <text class="desc">专门验证 bare import 与 /index import 的 confirm 互操作。</text>
  </view>
  <view class="card-list">
    <view
      wx:for="{{cards}}"
      wx:key="route"
      class="card"
      data-route="{{item.route}}"
      bindtap="onOpenCard"
    >
      <text class="card-title">{{item.title}}</text>
      <text class="card-desc">{{item.desc}}</text>
      <text class="card-route">{{item.route}}</text>
    </view>
  </view>
</view>
