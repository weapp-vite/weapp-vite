<view class="page">
  <text class="title">tdesign Dialog bare import</text>
  <text class="line">confirmType = {{confirmType}}</text>
  <text class="line">defaultType = {{defaultType}}</text>
  <text class="line">defaultConfirmType = {{defaultConfirmType}}</text>
  <text class="line">lastAction = {{lastAction}}</text>
  <text class="line">lastTrigger = {{lastTrigger}}</text>
  <text class="line">lastPayload = {{lastPayload || 'none'}}</text>
  <text class="line">lastError = {{lastError || 'none'}}</text>
  <text class="line">dialogVisible = {{dialogVisible}}</text>
  <text class="line">lastTitle = {{lastTitle || 'none'}}</text>
  <text class="line">counts = open {{openCount}}, settle {{settleCount}}</text>
  <text class="line">toastType = {{toastType}}</text>
  <text class="line">toastDefaultType = {{toastDefaultType}}</text>
  <text class="line">toastCount = {{toastCount}}</text>
  <text class="line">lastToastAction = {{lastToastAction}}</text>
  <text class="line">lastToastTrigger = {{lastToastTrigger}}</text>
  <text class="line">lastToastError = {{lastToastError || 'none'}}</text>
  <text class="line">lastToastMessage = {{lastToastMessage || 'none'}}</text>
  <button id="dialog-bare-open" class="button" bindtap="onOpenDialog">打开 confirm</button>
  <button id="dialog-bare-toast" class="button" bindtap="onOpenToast">打开 toast</button>
  <button class="button button-secondary" bindtap="_resetE2E">重置状态</button>
  <t-dialog id="t-dialog" />
  <t-toast id="t-toast" />
</view>
