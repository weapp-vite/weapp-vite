.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #eff6ff 0%, #eef2ff 100%);
}

.title,
.line {
  display: block;
  margin-bottom: 20rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d4ed8;
}

.line {
  font-size: 24rpx;
  color: #1e40af;
}

.button {
  margin-bottom: 16rpx;
}

.button-secondary {
  color: #1d4ed8;
  background: #bfdbfe;
}
