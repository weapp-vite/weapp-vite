{
  "package": "org.weappvite.quickapp.e2e",
  "name": "weapp-vite-quickapp-e2e",
  "versionName": "1.0.0",
  "versionCode": 1,
  "minPlatformVersion": 1070,
  "icon": "/Common/logo.png",
  "features": [
    {
      "name": "system.fetch"
    },
    {
      "name": "system.prompt"
    },
    {
      "name": "system.router"
    },
    {
      "name": "system.device"
    }
  ],
  "permissions": [
    {
      "origin": "*"
    }
  ],
  "config": {
    "logLevel": "log"
  },
  "router": {
    "entry": "native/reactivity",
    "pages": {
      "native/reactivity": {
        "component": "index"
      },
      "vue/reactivity": {
        "component": "index"
      },
      "native/list": {
        "component": "index"
      },
      "vue/list": {
        "component": "index"
      },
      "native/lifecycle": {
        "component": "index"
      },
      "vue/lifecycle": {
        "component": "index"
      },
      "vue/components": {
        "component": "index"
      },
      "vue/options": {
        "component": "index"
      },
      "native/api": {
        "component": "index"
      },
      "vue/api": {
        "component": "index"
      }
    }
  },
  "display": {
    "titleBar": false,
    "orientation": "portrait"
  }
}
