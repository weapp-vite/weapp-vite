{
  "name": "e2e-app-subpackage-shared-strategy-complex-a",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wv dev",
    "dev:open": "wv dev -o",
    "dev:duplicate": "WEAPP_CHUNK_STRATEGY=duplicate WEAPP_CHUNK_OUTDIR=dist-dev-duplicate wv dev",
    "dev:hoist": "WEAPP_CHUNK_STRATEGY=hoist WEAPP_CHUNK_OUTDIR=dist-dev-hoist wv dev",
    "dev:open:duplicate": "WEAPP_CHUNK_STRATEGY=duplicate WEAPP_CHUNK_OUTDIR=dist-dev-duplicate wv dev -o",
    "dev:open:hoist": "WEAPP_CHUNK_STRATEGY=hoist WEAPP_CHUNK_OUTDIR=dist-dev-hoist wv dev -o",
    "build": "wv build --platform weapp --skipNpm",
    "build:duplicate": "WEAPP_CHUNK_STRATEGY=duplicate WEAPP_CHUNK_OUTDIR=dist-duplicate wv build --platform weapp --skipNpm",
    "build:hoist": "WEAPP_CHUNK_STRATEGY=hoist WEAPP_CHUNK_OUTDIR=dist-hoist wv build --platform weapp --skipNpm",
    "build:matrix": "pnpm run build:duplicate && pnpm run build:hoist",
    "dev:ui": "wv dev --ui",
    "build:ui": "wv build --ui --platform weapp --skipNpm",
    "postinstall": "wv prepare"
  },
  "devDependencies": {
    "@weapp-vite/dashboard": "workspace:*",
    "picocolors": "^1.1.1",
    "weapp-vite": "workspace:*",
    "wevu": "workspace:*"
  }
}
