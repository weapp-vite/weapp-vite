<view class="page">
  <view class="hero">
    <text class="hero-title">socket.io-client transport</text>
    <text class="hero-desc">连接真实 Socket.IO 服务端，验证 polling 与 websocket 两种链路。</text>
  </view>

  <view class="panel">
    <text class="line">pageStatus = {{state.pageStatus}}</text>
    <text class="line">status = {{state.status}}</text>
    <text class="line">runCount = {{state.runCount}}</text>
    <text class="line">httpStatus = {{state.httpStatus}}</text>
    <text class="line">requestCount = {{state.requestCount}}</text>
    <text class="line">requestPath = {{state.requestPath}}</text>
    <text class="line">defaultTransport = {{defaultTransportName}}</text>
    <text class="line">websocketOnlyTransport = {{websocketOnlyTransportName}}</text>
    <text class="line">randomPushCount = {{randomPushCount}}</text>
    <text class="line">latestRandomMessage = {{latestRandomMessage}}</text>
    <text class="line">latestRandomSentAt = {{latestRandomSentAt}}</text>
    <button class="action" bindtap="runCase">重新执行 socket.io 校验</button>
  </view>

  <view class="panel">
    <text class="panel-title">payload</text>
    <text class="payload">{{state.payload}}</text>
  </view>

  <view wx:if="{{state.errorMessage}}" class="panel error">
    <text class="panel-title">error</text>
    <text class="payload">{{state.errorMessage}}</text>
  </view>
</view>
