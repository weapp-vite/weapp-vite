<view class="page">
  <view class="hero">
    <text class="hero-title">Request Clients Real Native E2E</text>
    <text class="hero-desc">这个 app 只用原生 App 与原生 Page，验证 request globals 在纯原生入口与请求库中的兼容性。</text>
  </view>

  <view class="card">
    <text class="card-title">App request globals probe</text>
    <text class="card-desc">fetchType = {{appProbe.fetchType}}</text>
    <text class="card-desc">urlAvailable = {{appProbe.urlAvailable}}</text>
    <text class="card-desc">xmlHttpRequestAvailable = {{appProbe.xmlHttpRequestAvailable}}</text>
    <text class="card-desc">webSocketAvailable = {{appProbe.webSocketAvailable}}</text>
  </view>

  <navigator
    wx:for="{{pages}}"
    wx:key="route"
    class="card nav-card"
    url="{{item.route}}"
  >
      <text class="card-title">{{item.title}}</text>
      <text class="card-desc">{{item.desc}}</text>
      <text class="card-route">{{item.route}}</text>
      <text class="card-link">点击进入</text>
  </navigator>
</view>
