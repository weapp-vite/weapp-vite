{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "tdesign-miniprogram/*": [
        "./node_modules/tdesign-miniprogram/miniprogram_dist/*"
      ]
    },
    "types": [
      "miniprogram-api-typings",
      "node",
      "vitest/globals",
      "vue/jsx"
    ]
  },
  "include": [
    "**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/dist",
    "**/miniprogram_dist",
    "**/.turbo",
    "**/.cache"
  ]
}
