{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": [
      "miniprogram-api-typings",
      "node",
      "vitest/globals",
      "vue/jsx"
    ]
  },
  "include": [
    "**/*"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "dist",
    "dist-*",
    "dist-plugin",
    "dist-web",
    "coverage",
    "**/dist",
    "**/dist/**",
    "**/dist-*",
    "**/dist-*/**",
    "**/dist-plugin",
    "**/dist-plugin/**",
    "**/dist-web",
    "**/dist-web/**",
    "**/build",
    "**/build/**",
    "**/miniprogram_dist",
    "**/miniprogram_dist/**",
    "**/miniprogram_npm",
    "**/miniprogram_npm/**",
    "**/.vite",
    "**/.vite/**",
    "**/.vite-inspect",
    "**/.vite-inspect/**",
    "**/.turbo",
    "**/.turbo/**",
    "**/.cache",
    "**/.cache/**",
    "**/coverage",
    "**/coverage/**",
    "**/__temp__",
    "**/__temp__/**",
    "**/.tmp",
    "**/.tmp/**",
    "**/.weapp-vite",
    "**/.weapp-vite/**",
    "**/.wevu-config",
    "**/.wevu-config/**"
  ]
}
