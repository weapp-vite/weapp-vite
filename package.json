{
  "name": "weapp-vite-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "author": "ice breaker <1324318532@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weapp-vite/weapp-vite.git"
  },
  "bugs": {
    "url": "https://github.com/weapp-vite/weapp-vite/issues"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build:all": "turbo run build",
    "build:core": "turbo run build --filter=./packages/* --filter=./packages-runtime/* --filter=./benchmarks/* --filter=./packages-private/* --filter=./@weapp-core/* --filter=./mpcore/packages/* --filter=./extensions/*",
    "build": "pnpm run build:core && node --import tsx scripts/print-dist-size-report.ts --scope=core",
    "build:ci": "turbo run build --filter=!./apps/* --filter=!./templates/* --filter=!./website --filter=!@weapp-vite/sfc-playground --filter=!e2e-issue-814-tailwind3 --filter=!e2e-issue-814-tailwind4-broken && node --import tsx scripts/print-dist-size-report.ts",
    "dev": "turbo run dev --filter=!./apps/* --filter=!./templates/* --filter=!./website",
    "build:pkgs": "turbo run build --filter=./packages/* --filter=./packages-runtime/* --filter=./benchmarks/* --filter=./packages-private/* --filter=./@weapp-core/* --filter=./mpcore/packages/*",
    "build:pkgs:ci": "turbo run build --filter=./packages/* --filter=./packages-runtime/* --filter=./benchmarks/* --filter=./packages-private/* --filter=./@weapp-core/* --filter=./mpcore/packages/* --filter=!@weapp-vite/sfc-playground",
    "build:pkgs:sourcemap": "turbo run build --filter=./packages/* --filter=./packages-runtime/* --filter=./benchmarks/* --filter=./packages-private/* --filter=./@weapp-core/* --filter=./mpcore/packages/* -- --sourcemap",
    "build:sourcemap": "turbo run build --filter=!./apps/* --filter=!./templates/* --filter=!./website --filter=!./packages/* --filter=!./packages-runtime/* --filter=!./benchmarks/* --filter=!./@weapp-core/* && pnpm run build:pkgs:sourcemap",
    "build:apps": "turbo run build --filter=./apps/* --filter=./templates/* --filter=!weapp-library",
    "build:docs": "turbo run build --filter=./website",
    "build:templates": "turbo run build --filter=./templates/*",
    "test": "vitest run",
    "test:serial": "cross-env WEAPP_VITE_TEST_MAX_WORKERS=1 vitest run",
    "test:coverage": "vitest run --coverage.enabled",
    "test:dev": "vitest",
    "test:types": "turbo run test:types",
    "lint": "turbo run lint",
    "release": "pnpm run changeset:catalog:auto && changeset",
    "changeset:deps:auto": "node --import tsx scripts/generate-dependency-upgrade-changeset.ts",
    "pr": "changeset pre enter alpha",
    "pr:beta": "changeset pre enter beta",
    "pr:rc": "changeset pre enter rc",
    "pr:exit": "changeset pre exit",
    "cv": "changeset version ",
    "ci": "turbo run --filter=!./apps/* --filter=!./templates/* --filter=!./website build",
    "ci:release": "turbo run --filter=!./apps/* --filter=!./templates/* --filter=!./website --filter=!e2e-issue-814-tailwind4-broken build",
    "//": " lint test",
    "e2e": "node --import tsx ./e2e/scripts/run-e2e-suite.ts full",
    "e2e:full": "node --import tsx ./e2e/scripts/run-e2e-suite.ts full-regression",
    "e2e:ci": "node --import tsx ./e2e/scripts/run-e2e-suite.ts ci",
    "e2e:ci:build-only": "vitest run -c ./e2e/vitest.e2e.ci.build-only.config.ts",
    "e2e:ci:hmr": "pnpm run e2e:ci:hmr:all",
    "e2e:ci:hmr:core": "pnpm run e2e:hmr:guard && pnpm run e2e:hmr:guard:shared-chunks-auto",
    "e2e:hmr:guard:auto-routes-hmr": "node --import tsx ./e2e/scripts/run-hmr-guard-suite.ts auto-routes-hmr",
    "e2e:ci:hmr:runtime": "pnpm vitest run --pool forks -c ./e2e/vitest.e2e.ci.config.ts e2e/ci/wevu-runtime.hmr.test.ts",
    "e2e:ci:hmr:auto-import": "vitest run -c ./e2e/vitest.e2e.ci.config.ts e2e/ci/auto-import-vue-sfc.test.ts",
    "e2e:ci:hmr:style-import": "vitest run -c ./e2e/vitest.e2e.ci.config.ts e2e/ci/style-import-vue.test.ts",
    "e2e:ci:hmr:all": "pnpm run e2e:ci:hmr:core && pnpm run e2e:ci:hmr:auto-import && pnpm run e2e:ci:hmr:style-import",
    "e2e:hmr:guard:config": "node --import tsx ./e2e/scripts/run-hmr-guard-suite.ts list",
    "e2e:hmr:guard:cleanup": "node --import tsx ./e2e/scripts/cleanup-dev-processes.ts",
    "e2e:hmr:guard": "node --import tsx ./e2e/scripts/run-hmr-guard-suite.ts full",
    "e2e:hmr:guard:smoke": "node --import tsx ./e2e/scripts/run-hmr-guard-suite.ts smoke",
    "e2e:hmr:guard:shared-chunks-auto": "node --import tsx ./e2e/scripts/run-hmr-guard-suite.ts shared-chunks-auto",
    "e2e:config": "node --import tsx ./e2e/scripts/run-e2e-suite.ts list",
    "e2e:devtools": "vitest run -c ./e2e/vitest.e2e.devtools.config.ts",
    "e2e:ide": "node --import tsx ./e2e/scripts/run-e2e-suite.ts ide-smoke --allow-failures",
    "e2e:ide:gate": "node --import tsx ./e2e/scripts/run-e2e-suite.ts ide-gate",
    "e2e:ide:full": "node --import tsx ./e2e/scripts/run-e2e-suite.ts ide-full",
    "e2e:ide:full:github-issues": "node --import tsx ./e2e/scripts/run-e2e-suite.ts \"ide-full:github-issues\"",
    "e2e:ide:full:wevu-features": "node --import tsx ./e2e/scripts/run-e2e-suite.ts \"ide-full:wevu-features\"",
    "e2e:ide:full:templates": "node --import tsx ./e2e/scripts/run-e2e-suite.ts \"ide-full:templates\"",
    "e2e:dev": "vitest -c ./e2e/vitest.e2e.config.ts",
    "e2e:parallel": "vitest run -c ./e2e/vitest.e2e.parallel.config.ts",
    "e2e:retail-parity": "vitest run -c ./e2e/vitest.e2e.retail-parity.config.ts",
    "e2e:web": "vitest run -c ./e2e/vitest.e2e.web.config.ts",
    "e2e:runtime-bench": "node --import tsx ./e2e/scripts/run-runtime-bench.ts",
    "e2e:u": "cross-env E2E_FULL_MATRIX=1 vitest run -u -c ./e2e/vitest.e2e.config.ts",
    "e2e:wevu-runtime": "vitest run -c ./e2e/vitest.e2e.config.ts e2e/ci/wevu-runtime.*.test.ts e2e/ide/wevu-runtime.*.test.ts",
    "e2e:wevu-runtime:weapp": "vitest run -c ./e2e/vitest.e2e.config.ts e2e/ide/wevu-runtime.weapp.test.ts",
    "e2e:wevu-features": "vitest run -c ./e2e/vitest.e2e.config.ts e2e/ci/wevu-features.build.test.ts e2e/ide/template-wevu-features-app.test.ts e2e/ide/wevu-features.runtime.behavior.test.ts e2e/ide/wevu-features.runtime.subpath.test.ts e2e/ide/wevu-features.runtime.router.test.ts",
    "e2e:wevu-subpackage-placement": "vitest run -c ./e2e/vitest.e2e.config.ts e2e/ci/wevu-subpackage-placement.build.test.ts && vitest run -c ./e2e/vitest.e2e.devtools.config.ts e2e/ide/wevu-subpackage-placement.runtime.test.ts",
    "e2e:chunks": "pnpm run e2e:chunks:ci && pnpm run e2e:chunks:ide",
    "e2e:chunks:ci": "vitest run -c ./e2e/vitest.e2e.config.ts e2e/ci/chunk-modes.e2e.test.ts",
    "e2e:chunks:ide": "pnpm run e2e:chunks:ide:duplicate && pnpm run e2e:chunks:ide:hoist && pnpm run e2e:chunks:ide:extras",
    "e2e:chunks:ide:duplicate": "vitest run -c ./e2e/vitest.e2e.devtools.config.ts e2e/ide/chunk-modes.runtime.duplicate.test.ts",
    "e2e:chunks:ide:hoist": "vitest run -c ./e2e/vitest.e2e.devtools.config.ts e2e/ide/chunk-modes.runtime.hoist.test.ts",
    "e2e:chunks:ide:extras": "vitest run -c ./e2e/vitest.e2e.devtools.config.ts e2e/ide/chunk-modes.runtime.extras.test.ts",
    "e2e:chunks:ide:trust-project": "cross-env WEAPP_VITE_E2E_TRUST_PROJECT=1 vitest run -c ./e2e/vitest.e2e.devtools.config.ts e2e/ide/chunk-modes.runtime.duplicate.test.ts e2e/ide/chunk-modes.runtime.hoist.test.ts e2e/ide/chunk-modes.runtime.extras.test.ts",
    "e2e:chunks:ide:retry-debug": "cross-env WEAPP_VITE_E2E_RELUNCH_READY_TIMEOUT=30000 WEAPP_VITE_E2E_RELUNCH_RETRIES=6 WEAPP_VITE_E2E_RELUNCH_RETRY_DELAY=500 WEAPP_VITE_E2E_RELUNCH_SETTLE_DELAY=500 vitest run -c ./e2e/vitest.e2e.devtools.config.ts e2e/ide/chunk-modes.runtime.duplicate.test.ts e2e/ide/chunk-modes.runtime.hoist.test.ts e2e/ide/chunk-modes.runtime.extras.test.ts",
    "e2e:chunks:tour:manual": "node scripts/chunk-modes-devtools-carousel.mjs --mode manual",
    "e2e:chunks:tour:auto": "node scripts/chunk-modes-devtools-carousel.mjs --mode auto",
    "e2e:chunks:subpackage-complex:build:matrix": "pnpm run e2e:chunks:subpackage-complex:build:matrix:a && pnpm run e2e:chunks:subpackage-complex:build:matrix:b",
    "e2e:chunks:subpackage-complex:build:matrix:a": "pnpm --dir e2e-apps/subpackage-shared-strategy-complex-a run build:matrix",
    "e2e:chunks:subpackage-complex:build:matrix:b": "pnpm --dir e2e-apps/subpackage-shared-strategy-complex-b run build:matrix",
    "e2e:chunks:subpackage-complex:build:duplicate:a": "pnpm --dir e2e-apps/subpackage-shared-strategy-complex-a run build:duplicate",
    "e2e:chunks:subpackage-complex:build:hoist:a": "pnpm --dir e2e-apps/subpackage-shared-strategy-complex-a run build:hoist",
    "e2e:chunks:subpackage-complex:build:duplicate:b": "pnpm --dir e2e-apps/subpackage-shared-strategy-complex-b run build:duplicate",
    "e2e:chunks:subpackage-complex:build:hoist:b": "pnpm --dir e2e-apps/subpackage-shared-strategy-complex-b run build:hoist",
    "e2e:chunks:subpackage-complex:ci": "vitest run -c ./e2e/vitest.e2e.config.ts e2e/ci/subpackage-shared-strategy-complex.e2e.test.ts",
    "e2e:chunks:subpackage-complex:ide": "vitest run -c ./e2e/vitest.e2e.devtools.config.ts e2e/ide/subpackage-shared-strategy-complex.runtime.test.ts",
    "e2e:chunks:subpackage-complex:ide:trust-project": "cross-env WEAPP_VITE_E2E_TRUST_PROJECT=1 vitest run -c ./e2e/vitest.e2e.devtools.config.ts e2e/ide/subpackage-shared-strategy-complex.runtime.test.ts",
    "e2e:chunks:subpackage-complex:ide:retry-debug": "cross-env WEAPP_VITE_E2E_RELUNCH_READY_TIMEOUT=30000 WEAPP_VITE_E2E_RELUNCH_RETRIES=6 WEAPP_VITE_E2E_RELUNCH_RETRY_DELAY=500 WEAPP_VITE_E2E_RELUNCH_SETTLE_DELAY=500 vitest run -c ./e2e/vitest.e2e.devtools.config.ts e2e/ide/subpackage-shared-strategy-complex.runtime.test.ts",
    "e2e:chunks:subpackage-complex:all": "pnpm run e2e:chunks:subpackage-complex:build:matrix && pnpm run e2e:chunks:subpackage-complex:ci && pnpm run e2e:chunks:subpackage-complex:ide",
    "e2e:lib-mode": "vitest run -c ./e2e/vitest.e2e.config.ts e2e/ci/lib-mode.e2e.test.ts",
    "check:e2e-ide-shared-launch": "node --import tsx scripts/check-e2e-ide-shared-launch.ts",
    "check:watch:file-name-conflict": "node scripts/check-watch-file-name-conflict.mjs",
    "check:create-weapp-vite-changeset": "tsx scripts/check-create-weapp-vite-changeset.ts",
    "check:publishable-workspace-changeset": "tsx scripts/check-publishable-workspace-changeset.ts",
    "check:weapp-core-constants-changeset": "tsx scripts/check-weapp-core-constants-changeset.ts",
    "check:weapp-core-constants-dependency-range": "tsx scripts/check-weapp-core-constants-dependency-range.ts",
    "check:vscode-extension-changeset": "tsx scripts/check-vscode-extension-changeset.ts",
    "check:changeset:frontmatter": "node scripts/check-changeset-frontmatter.mjs",
    "check:rolldown:report": "node scripts/print-rolldown-versions.mjs --mode report",
    "check:rolldown:single-version": "node scripts/print-rolldown-versions.mjs",
    "changeset:catalog:auto": "node --import tsx scripts/generate-catalog-changeset.ts",
    "check:catalog-changeset": "node --import tsx scripts/check-catalog-changeset.ts",
    "catalog:sync:rolldown": "node scripts/print-rolldown-versions.mjs --mode sync",
    "catalog:sync:create-weapp-vite": "node --import tsx packages/create-weapp-vite/scripts/generate-template-catalog.ts",
    "deps:up": "node --import tsx scripts/upgrade-workspace-deps.ts",
    "publish-packages": "pnpm run catalog:sync:create-weapp-vite && pnpm run changeset:catalog:auto && pnpm run check:catalog-changeset && pnpm run check:create-weapp-vite-changeset && pnpm run check:publishable-workspace-changeset && pnpm run check:weapp-core-constants-dependency-range && pnpm run check:rolldown:single-version && pnpm run ci:release && turbo run test && turbo run test:types && changeset version && changeset publish",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "node scripts/postinstall-sync.mjs",
    "prepare": "husky",
    "commit": "commit",
    "script:init": "monorepo init",
    "script:sync": "monorepo sync",
    "script:clean": "monorepo clean",
    "script:mirror": "monorepo mirror",
    "sync:project-private-lib-version": "node scripts/sync-project-private-lib-version.mjs",
    "skills:link": "node scripts/link-agent-skills.mjs",
    "skills:link:dry": "node scripts/link-agent-skills.mjs --dry-run",
    "skills:check:yaml": "node skills/scripts/validate-skills-yaml.mjs",
    "skills:score": "node skills/scripts/score-skill-trigger-regression.mjs",
    "skills:score:json": "node skills/scripts/score-skill-trigger-regression.mjs --json",
    "seo-audit": "node --import tsx scripts/seo/seo-audit.ts",
    "seo-audit:strict": "node --import tsx scripts/seo/seo-audit.ts --strict",
    "seo-enrich-frontmatter": "node --import tsx scripts/seo/seo-enrich-frontmatter.ts",
    "seo-normalize-keywords": "node --import tsx scripts/seo/seo-normalize-keywords.ts",
    "seo-quality-check": "node --import tsx scripts/seo/seo-quality-check.ts",
    "seo-quality-report": "node --import tsx scripts/seo/seo-quality-report.ts",
    "seo-generate-llms-index": "node --import tsx scripts/seo/seo-generate-llms-index.ts",
    "seo:quality:strict": "node --import tsx scripts/seo/seo-quality-check.ts --strict",
    "seo:prepare": "pnpm seo-generate-llms-index && pnpm seo-quality-report",
    "community:showcase:sync": "node --import tsx scripts/sync-community-showcase.ts",
    "builtin": "tsx scripts/builtin.ts",
    "docs:wechat:mirror": "node --import tsx ./scripts/wechat-docs-mirror/index.ts",
    "auto-import:components": "tsx scripts/update-auto-import-components.ts",
    "vite:patch": "tsx scripts/vite-patch.ts",
    "commitlint": "commitlint --edit"
  },
